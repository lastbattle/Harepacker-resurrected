<gui:ThemedDialogWindow x:Class="HaRepacker.GUI.NewForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gui="clr-namespace:HaRepacker.GUI" Width="600" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <gui:ThemedDialogWindow.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries></ResourceDictionary></gui:ThemedDialogWindow.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Choose the archive type and encoding options." Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/></StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock x:Name="nameLabel" Text="Name" VerticalAlignment="Center"/><Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="nameBox"/><TextBlock x:Name="extensionLabel" Grid.Column="1" Text=".wz" Margin="8,0,0,0" VerticalAlignment="Center"/></Grid>
                <TextBlock x:Name="typeHeader" Grid.Row="1" Text="Type" Margin="0,14,0,0" VerticalAlignment="Top"/><WrapPanel Grid.Row="1" Grid.Column="1" Margin="0,12,0,0"><RadioButton x:Name="regBox" Content="Regular" IsChecked="True" GroupName="Type" Checked="Type_CheckedChanged"/><RadioButton x:Name="listBox" Content="List" GroupName="Type" Margin="18,0,0,0" Checked="Type_CheckedChanged"/><RadioButton x:Name="hotfixBox" Content="Hotfix Data.wz" GroupName="Type" Margin="18,0,0,0" Checked="Type_CheckedChanged"/></WrapPanel>
                <TextBlock x:Name="copyrightLabel" Grid.Row="2" Text="Copyright" Margin="0,14,0,0" VerticalAlignment="Center"/><TextBox x:Name="copyrightBox" Grid.Row="2" Grid.Column="1" Margin="0,12,0,0"/>
                <TextBlock x:Name="encryptionLabel" Grid.Row="3" Text="Encryption" Margin="0,14,0,0" VerticalAlignment="Center"/><ComboBox x:Name="encryptionBox" Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" SelectionChanged="EncryptionBox_SelectionChanged"/>
                <TextBlock x:Name="versionLabel" Grid.Row="4" Text="Version" Margin="0,14,0,0" VerticalAlignment="Center"/><TextBox x:Name="versionBox" Grid.Row="4" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,12,0,0" InputScope="Number"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button x:Name="cancelButton" Content="Cancel" Width="100" IsCancel="True" Click="cancelButton_Click"/><Button x:Name="okButton" Content="OK" Width="120" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="okButton_Click"/></StackPanel>
    </Grid>
</gui:ThemedDialogWindow>
