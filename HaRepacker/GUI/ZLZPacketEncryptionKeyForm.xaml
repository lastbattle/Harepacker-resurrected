<gui:ThemedDialogWindow x:Class="HaRepacker.GUI.ZLZPacketEncryptionKeyForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:gui="clr-namespace:HaRepacker.GUI"
        Title="ZLZ AES Encryption keys" Width="760" Height="600" MinWidth="620" MinHeight="460" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13">
    <gui:ThemedDialogWindow.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></gui:ThemedDialogWindow.Resources>
    <Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Extracted AES key formats for use with Odin and MapleShark tooling." Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/></StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="AES Keys (Odin):" Style="{StaticResource HareSectionTitleStyle}"/><TextBox x:Name="textBox_aesOdin" Grid.Row="1" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/></Grid></Border>
        <Border Grid.Row="2" Style="{StaticResource HareCardStyle}" Margin="0,12,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="AES Keys (MapleShark):" Style="{StaticResource HareSectionTitleStyle}"/><TextBox x:Name="textBox_aesOthers" Grid.Row="1" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/></Grid></Border>
        <Button Grid.Row="3" Content="Close" Width="110" HorizontalAlignment="Right" Margin="0,18,0,0" IsCancel="True"/>
    </Grid>
</gui:ThemedDialogWindow>
