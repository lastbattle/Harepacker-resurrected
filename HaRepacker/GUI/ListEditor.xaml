<Window x:Class="HaRepacker.GUI.ListEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="760" Height="560" MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}"
        Closing="ListEditor_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel>
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Margin="0,4,0,0" Text="Edit one encrypted list entry per line."
                           Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
            <Button x:Name="saveButton" DockPanel.Dock="Right" MinWidth="96"
                    HorizontalAlignment="Right" Style="{StaticResource HarePrimaryButtonStyle}"
                    Click="SaveButton_Click" Content="Save"/>
        </DockPanel>
        <Border Grid.Row="2" Style="{StaticResource HareCardStyle}" Padding="0">
            <TextBox x:Name="textBox" AcceptsReturn="True" AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas" TextWrapping="NoWrap"
                     BorderThickness="0" Padding="12"/>
        </Border>
    </Grid>
</Window>
