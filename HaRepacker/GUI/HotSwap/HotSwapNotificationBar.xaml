<UserControl x:Class="HaRepacker.GUI.HotSwap.HotSwapNotificationBar"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Height="32" Visibility="Collapsed">
 <UserControl.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
  <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
 </ResourceDictionary.MergedDictionaries></ResourceDictionary></UserControl.Resources>
 <Border x:Name="statusBorder" Padding="12,6" Background="{DynamicResource HareSurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
  <TextBlock x:Name="messageText" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
 </Border>
</UserControl>
