<gui:ThemedDialogWindow x:Class="HaRepacker.GUI.WzStringSearchForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gui="clr-namespace:HaRepacker.GUI" Title="WZ String searcher" Width="900" Height="650" MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13">
    <gui:ThemedDialogWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </gui:ThemedDialogWindow.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Search names and descriptions across loaded WZ data, then copy the matching ID bytes." Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="label11" Text="Query:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox x:Name="textBox_itemidFind" Grid.Column="1" Text="Sword" TextChanged="textBox_itemidFind_TextChanged"/>
                </Grid>
                <WrapPanel Margin="0,14,0,0">
                    <CheckBox x:Name="checkBox_searcheq" Content="EQ"/>
                    <CheckBox x:Name="checkBox_searchuse" Content="USE" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchsetup" Content="SETUP" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchetc" Content="ETC" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchcash" Content="CASH" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchquest" Content="QUEST" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchNPC" Content="NPC" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchMaps" Content="MAPS" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkbox_searchSkill" Content="SKILLS" Margin="14,0,0,0"/>
                    <CheckBox x:Name="checkBox_searchJobs" Content="JOBS" Margin="14,0,0,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource HareCardStyle}" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ComboBox x:Name="comboBox_hexlist" SelectionChanged="comboBox_hexlist_SelectedIndexChanged"/>
                <TextBox x:Name="label_itemname" Grid.Row="1" Text="Output Item Name" IsReadOnly="True" Margin="0,12,0,0" FontWeight="SemiBold"/>
                <TextBox x:Name="label_itemdesc" Grid.Row="2" Text="Output" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="90" Margin="0,8,0,0"/>
                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="label5" Text="Integer" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="textBox6" Grid.Column="1" Text="0" TextChanged="in_textchanged" InputScope="Number"/>
                    <TextBlock x:Name="label6" Grid.Column="2" Text="Hex:" VerticalAlignment="Center" Margin="18,0,10,0"/>
                    <TextBox x:Name="textBox5" Grid.Column="3" Text="0xFF" IsReadOnly="True"/>
                </Grid>
            </Grid>
        </Border>
        <Button Grid.Row="3" Content="Close" Width="110" HorizontalAlignment="Right" Margin="0,18,0,0" IsCancel="True"/>
    </Grid>
</gui:ThemedDialogWindow>
