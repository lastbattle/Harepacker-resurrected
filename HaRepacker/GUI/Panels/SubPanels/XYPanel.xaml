<UserControl x:Class="HaRepacker.GUI.Panels.SubPanels.XYPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HaRepacker.GUI.Panels.SubPanels"
             mc:Ignorable="d" 
             d:DesignHeight="160" d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Width="300" Height="160" Background="{StaticResource HareCanvasBrush}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <!-- X -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="X: " Foreground="{StaticResource HareTextBrush}" FontSize="17"/>
                <TextBox x:Name="xBox" Width="200" Margin="20,0,0,0" Text="0" FontSize="17"
                         InputScope="Number" TextAlignment="Center"
                         TextChanged="xBox_TextChanged"/>
            </StackPanel>

            <!-- Y -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Y: " Foreground="{StaticResource HareTextBrush}" FontSize="17"/>
                <TextBox x:Name="yBox" Width="200" Margin="20,0,0,0" Text="0" FontSize="17"
                         InputScope="Number"  TextAlignment="Center"
                         TextChanged="yBox_TextChanged"/>
            </StackPanel>
        </StackPanel>

        <Button x:Name="button_ApplyChanges" Content="Apply" Style="{StaticResource HarePrimaryButtonStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="250" Margin="10" Height="30"
                Click="button_ApplyChanges_Click"/>
    </Grid>
</UserControl>
