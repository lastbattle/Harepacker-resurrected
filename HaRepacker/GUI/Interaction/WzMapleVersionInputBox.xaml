<gui:ThemedDialogWindow x:Class="HaRepacker.GUI.Interaction.WzMapleVersionInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gui="clr-namespace:HaRepacker.GUI" Width="520" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13">
    <gui:ThemedDialogWindow.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></gui:ThemedDialogWindow.Resources>
    <Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Choose the MapleStory encryption version for this import." Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/></StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0"><StackPanel><TextBlock x:Name="label_wzEncrytionType"/><ComboBox x:Name="comboBox_wzEncryptionType" Margin="0,10,0,0" SelectionChanged="comboBox_Encryption_SelectedIndexChanged"/></StackPanel></Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button x:Name="cancelButton" Content="Cancel" Width="100" IsCancel="True" Click="cancelButton_Click"/><Button x:Name="okButton" Content="OK" Width="120" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="okButton_Click"/></StackPanel>
    </Grid>
</gui:ThemedDialogWindow>
