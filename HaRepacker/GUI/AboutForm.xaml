<gui:ThemedDialogWindow x:Class="HaRepacker.GUI.AboutForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gui="clr-namespace:HaRepacker.GUI"
        Width="620" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}"
        Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13">
    <gui:ThemedDialogWindow.Resources>
        <ResourceDictionary><ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
        </ResourceDictionary.MergedDictionaries></ResourceDictionary>
    </gui:ThemedDialogWindow.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock x:Name="productName" Text="HaRepacker" Style="{StaticResource HarePageTitleStyle}"/>
            <TextBlock Text="WZ editor and archive toolkit" Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0">
            <StackPanel>
                <TextBlock x:Name="copyrightText" TextWrapping="Wrap"/>
                <Separator Margin="0,14"/>
                <TextBlock x:Name="developerText"/>
                <TextBlock x:Name="creditsText" Margin="0,4,0,0"/>
                <TextBlock x:Name="forkText" Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/>
                <Button x:Name="repositoryLink" Content="Repository" HorizontalAlignment="Left" Margin="0,14,0,0"
                        Padding="0" BorderThickness="0" Background="Transparent" Foreground="{StaticResource HareAccentBrush}"
                        Click="linkLabel1_LinkClicked"/>
            </StackPanel>
        </Border>
        <Button x:Name="okButton" Grid.Row="2" Content="OK" Width="110" HorizontalAlignment="Right" Margin="0,18,0,0"
                IsDefault="True" IsCancel="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="button1_Click"/>
    </Grid>
</gui:ThemedDialogWindow>
