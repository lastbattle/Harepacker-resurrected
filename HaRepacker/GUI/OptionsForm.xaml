<gui:ThemedDialogWindow x:Class="HaRepacker.GUI.OptionsForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gui="clr-namespace:HaRepacker.GUI" Width="680" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13">
    <gui:ThemedDialogWindow.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></gui:ThemedDialogWindow.Resources>
    <Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Configure archive loading, export formatting, and application behavior." Style="{StaticResource HareMutedTextStyle}" Margin="0,4,0,0"/></StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0"><StackPanel>
            <TextBlock x:Name="generalHeader" Text="General" Style="{StaticResource HareSectionTitleStyle}"/>
            <CheckBox x:Name="sortBox" Margin="0,12,0,0"/><CheckBox x:Name="loadRelated" Margin="0,9,0,0"/><CheckBox x:Name="apngIncompEnable" Margin="0,9,0,0"/><CheckBox x:Name="autoAssociateBox" Margin="0,9,0,0"/>
            <Separator Margin="0,16"/>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <CheckBox x:Name="defXmlFolderEnable" VerticalAlignment="Center" Checked="defXmlFolderEnable_CheckedChanged" Unchecked="defXmlFolderEnable_CheckedChanged"/><TextBox x:Name="defXmlFolderBox" Grid.Column="1"/><Button x:Name="browseButton" Grid.Column="2" Width="44" Margin="8,0,0,0" Click="browse_Click"/>
            </Grid>
            <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="120"/><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="indentationLabel" VerticalAlignment="Center"/><TextBox x:Name="indentBox" Grid.Column="1" InputScope="Number"/>
                <TextBlock x:Name="lineBreakLabel" Grid.Column="2" Margin="18,0,0,0" VerticalAlignment="Center"/><ComboBox x:Name="lineBreakBox" Grid.Column="3"/>
            </Grid>
            <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock x:Name="themeLabel" VerticalAlignment="Center"/><ComboBox x:Name="themeColorComboBox" Grid.Column="1"/></Grid>
        </StackPanel></Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button x:Name="cancelButton" Content="Cancel" Width="100" IsCancel="True" Click="cancelButton_Click"/><Button x:Name="okButton" Content="OK" Width="120" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="okButton_Click"/></StackPanel>
    </Grid>
</gui:ThemedDialogWindow>
