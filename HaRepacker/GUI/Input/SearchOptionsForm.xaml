<Window x:Class="HaRepacker.GUI.Input.SearchOptionsForm" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Width="540" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
 <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
<ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
</ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
 <Grid Margin="18"><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
 <Border Style="{StaticResource HareCardStyle}"><StackPanel>
  <TextBlock Text="Search behavior" Style="{StaticResource HareSectionTitleStyle}" Margin="0,0,0,10"/>
  <CheckBox x:Name="parseImages" Content="Parse images while searching" Margin="0,0,0,9"/>
  <CheckBox x:Name="searchValues" Content="Search string values"/>
 </StackPanel></Border>
 <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
  <Button x:Name="cancelButton" Content="Cancel" Width="90" IsCancel="True" Click="Cancel_Click"/>
  <Button x:Name="okButton" Content="OK" Width="100" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/>
 </StackPanel></Grid>
</Window>
