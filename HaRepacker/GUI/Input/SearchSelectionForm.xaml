<Window x:Class="HaRepacker.GUI.SearchSelectionForm" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Width="660" Height="520" MinWidth="420" MinHeight="300" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
 <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
<ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
</ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
 <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
  <StackPanel Margin="2,0,2,10">
   <TextBlock Text="Select a result to navigate to it." Style="{StaticResource HareMutedTextStyle}" Margin="0,2,0,0"/></StackPanel>
  <Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Padding="0">
   <ListBox x:Name="listBox_items" BorderThickness="0" SelectionChanged="ListBox_SelectionChanged"/>
  </Border>
 </Grid>
</Window>
