<Window x:Class="HaRepacker.GUI.Input.SoundInputBox" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Width="500" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
 <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
<ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
</ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
 <Grid Margin="18"><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
 <Border Style="{StaticResource HareCardStyle}"><StackPanel>
  <TextBlock x:Name="labelName" Text="Name:" Style="{StaticResource HareSectionTitleStyle}" Margin="0,0,0,5"/>
  <TextBox x:Name="nameBox" KeyDown="Input_KeyDown" Margin="0,0,0,12"/>
  <TextBlock x:Name="labelPath" Text="Path:" Style="{StaticResource HareSectionTitleStyle}" Margin="0,0,0,5"/>
  <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
   <TextBox x:Name="pathBox" KeyDown="Input_KeyDown"/>
   <Button x:Name="browseButton" Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="BrowseButton_Click"/>
  </Grid>
 </StackPanel></Border>
 <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
  <Button x:Name="cancelButton" Content="Cancel" Width="90" IsCancel="True" Click="CancelButton_Click"/>
  <Button x:Name="okButton" Content="OK" Width="100" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="OkButton_Click"/>
 </StackPanel></Grid>
</Window>
