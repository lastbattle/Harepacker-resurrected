<gui:ThemedDialogWindow x:Class="Footholds.Edit" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:gui="clr-namespace:HaRepacker.GUI" Width="560" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13" Loaded="Edit_Load">
 <gui:ThemedDialogWindow.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></gui:ThemedDialogWindow.Resources>
 <Grid Margin="24"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="Edit foothold" Style="{StaticResource HarePageTitleStyle}"/><Border Grid.Row="1" Style="{StaticResource HareCardStyle}" Margin="0,18,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
 <TextBlock Text="Previous foothold"/><TextBlock x:Name="PrevLbl" Grid.Column="1" Text="*"/><TextBox x:Name="PrevTBox" Grid.Column="2" InputScope="Number"/><TextBlock Grid.Row="1" Text="Next foothold" Margin="0,10,0,0"/><TextBlock x:Name="NextLbl" Grid.Row="1" Grid.Column="1" Text="*" Margin="0,10,0,0"/><TextBox x:Name="NextTBox" Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" InputScope="Number"/><TextBlock Grid.Row="2" Text="Force" Margin="0,10,0,0"/><TextBlock x:Name="ForceLbl" Grid.Row="2" Grid.Column="1" Text="None" Margin="0,10,0,0"/><TextBox x:Name="ForceTBox" Grid.Row="2" Grid.Column="2" Margin="0,8,0,0" InputScope="Number"/></Grid></Border><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button x:Name="CancelBtn" Content="Cancel" Width="100" IsCancel="True" Click="CancelBtn_Click"/><Button x:Name="ConfirmBtn" Content="Confirm" Width="120" Margin="8,0,0,0" Style="{StaticResource HarePrimaryButtonStyle}" Click="Cancel_Click"/></StackPanel></Grid>
