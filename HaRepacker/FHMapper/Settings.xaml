<gui:ThemedDialogWindow x:Class="HaRepacker.Settings" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:gui="clr-namespace:HaRepacker.GUI" xmlns:shared="clr-namespace:HaSharedLibrary.GUI;assembly=HaSharedLibrary" Width="650" Height="560" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" Foreground="{DynamicResource HareTextBrush}" FontFamily="Segoe UI" FontSize="13" Loaded="Settings_Load" Title="Settings">
 <gui:ThemedDialogWindow.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></gui:ThemedDialogWindow.Resources>
 <Grid Margin="24"><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TabControl x:Name="SettingsTab">
  <TabItem Header="Footholds"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Default prev value"/><TextBox x:Name="PrevTBox" Grid.Column="1" InputScope="Number"/><CheckBox x:Name="PrevCBox" Grid.Column="2" Content="Override" Margin="10,0,0,0"/><TextBlock Grid.Row="1" Text="Default next value" Margin="0,12,0,0"/><TextBox x:Name="NextTBox" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" InputScope="Number"/><CheckBox x:Name="NextCBox" Grid.Row="1" Grid.Column="2" Content="Override" Margin="10,10,0,0"/><TextBlock Grid.Row="2" Text="Default force value" Margin="0,12,0,0"/><TextBox x:Name="ForceTBox" Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" InputScope="Number"/><CheckBox x:Name="ForceCBox" Grid.Row="2" Grid.Column="2" Content="Override" Margin="10,10,0,0"/></Grid></TabItem>
  <TabItem Header="Portals"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="Default X coordinate"/><TextBox x:Name="XTBox" Grid.Column="1" InputScope="Number"/><CheckBox x:Name="XCBox" Grid.Column="2" Content="Override" Margin="10,0,0,0"/><TextBlock Grid.Row="1" Text="Default Y coordinate" Margin="0,12,0,0"/><TextBox x:Name="YTBox" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" InputScope="Number"/><CheckBox x:Name="YCBox" Grid.Row="1" Grid.Column="2" Content="Override" Margin="10,10,0,0"/><TextBlock Grid.Row="2" Text="Default portal type" Margin="0,12,0,0"/><TextBox x:Name="TypeTBox" Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" InputScope="Number"/><CheckBox x:Name="TypeCBox" Grid.Row="2" Grid.Column="2" Content="Override" Margin="10,10,0,0"/></Grid></TabItem>
  <TabItem Header="Other"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="Default filepath"/><TextBox x:Name="FilepathTBox" Grid.Column="1"/><Button x:Name="OpenFileBtn" Grid.Column="2" Content="..." Width="42" Margin="8,0,0,0" Click="OpenFileBtn_Click"/><CheckBox x:Name="FilepathCBox" Grid.Column="3" Content="Override" Margin="10,0,0,0"/><TextBlock Grid.Row="1" Text="Default render size" Margin="0,12,0,0"/><shared:NumericTextBox x:Name="SizeTBox" AllowDecimal="True" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"/><CheckBox x:Name="SizeCBox" Grid.Row="1" Grid.Column="3" Content="Override" Margin="10,10,0,0"/></Grid></TabItem>
 </TabControl><StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button x:Name="CancelBtn" Content="Cancel" Width="100" IsCancel="True" Click="CancelBtn_Click"/><Button x:Name="ConfirmBtn" Content="Confirm" Width="120" Margin="8,0,0,0" Style="{StaticResource HarePrimaryButtonStyle}" Click="ConfirmBtn_Click"/></StackPanel></Grid>
</gui:ThemedDialogWindow>
