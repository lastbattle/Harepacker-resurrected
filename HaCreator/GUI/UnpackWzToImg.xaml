<Window x:Class="HaCreator.GUI.UnpackWzToImg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_Extract_WZ_Data_42667B}" Width="840" Height="700"
        MinWidth="720" MinHeight="580"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}">
    <Window.Resources>
        <ResourceDictionary><ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
        </ResourceDictionary.MergedDictionaries></ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,4,0,0" Opacity="0.72"
                       Text="{dialogLoc:DialogText Dialog_Choose_a_MapleStory_installation_select_the_data_groups_528310}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{dialogLoc:DialogText Dialog_Export_folder_B41FF5}" VerticalAlignment="Center"/>
            <TextBox x:Name="textBox_path" Grid.Column="1" Margin="0,0,8,8" TextChanged="textBox_path_TextChanged"/>
            <Button x:Name="button_pathSelect" Grid.Column="2" Margin="0,0,0,8" Padding="14,5" Content="{dialogLoc:DialogText Dialog_Browse_93C6B6}" Click="button_pathSelect_Click"/>

            <TextBlock Grid.Row="1" Text="{dialogLoc:DialogText Dialog_Version_name_C5BE1C}" VerticalAlignment="Center"/>
            <TextBox x:Name="textBox_versionName" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" TextChanged="textBox_versionName_TextChanged"/>

            <TextBlock Grid.Row="2" Text="{dialogLoc:DialogText Dialog_Encryption_82F4E7}" VerticalAlignment="Center"/>
            <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="{dialogLoc:DialogText Dialog_Read_9B9A8D}" Opacity="0.7"/><ComboBox x:Name="versionBox"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="{dialogLoc:DialogText Dialog_Write_3F0092}" Opacity="0.7"/><ComboBox x:Name="comboBox_writeEncryption"/></StackPanel>
            </Grid>

            <TextBlock Grid.Row="3" Text="{dialogLoc:DialogText Dialog_Client_locale_0C3F96}" VerticalAlignment="Center"/>
            <ComboBox x:Name="comboBox_localisation" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" IsEnabled="False"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,18,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="{dialogLoc:DialogText Dialog_WZ_data_groups_EB7F0F}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button x:Name="button_scanWzFiles" Grid.Column="1" Margin="8,0,0,0" Padding="12,5" Content="{dialogLoc:DialogText Dialog_Scan_installation_D2939B}" Click="button_scanWzFiles_Click"/>
            <Button x:Name="button_selectAll" Grid.Column="2" Margin="8,0,0,0" Padding="12,5" Content="{dialogLoc:DialogText Dialog_Select_all_1FC9A3}" Click="button_selectAll_Click"/>
            <Button x:Name="button_selectNone" Grid.Column="3" Margin="8,0,0,0" Padding="12,5" Content="{dialogLoc:DialogText Dialog_Select_none_41AFE0}" Click="button_selectNone_Click"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <ListBox x:Name="checkedListBox_wzFiles" BorderThickness="0"/>
            </Border>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Activity_log_A9D562}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="listBox_log" BorderThickness="0" FontFamily="Consolas" FontSize="11"/>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,14,0,0">
            <TextBlock x:Name="textBox_status" Text="{dialogLoc:DialogText Dialog_Select_a_MapleStory_installation_to_begin_1BD82A}" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <ProgressBar x:Name="progressBar" Height="8" Minimum="0" Maximum="100"/>
        </StackPanel>

        <Grid Grid.Row="5" Margin="0,18,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="1" Margin="0,0,8,0" Padding="20,7" Content="{dialogLoc:DialogText Dialog_Close_7D9EB7}" IsCancel="True"/>
            <Button x:Name="button_unpack" Grid.Column="2" Padding="24,7" Content="{dialogLoc:DialogText Dialog_Extract_C15301}" IsDefault="True" Click="button_unpack_Click"/>
        </Grid>
    </Grid>
</Window>
