                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Quest -->
        <DataTemplate x:Key="ActQuestTemplate">
            <StackPanel Orientation="Vertical">
                <ListBox ItemsSource="{Binding QuestReqs}" MinHeight="30" 
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
