                <DataTrigger Binding="{Binding CheckType}" Value="{x:Static local:QuestEditorCheckType.Start}">
                    <Setter TargetName="CheckContent" Property="ContentTemplate" Value="{StaticResource CheckStartTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CheckType}" Value="{x:Static local:QuestEditorCheckType.End}">
                    <Setter TargetName="CheckContent" Property="ContentTemplate" Value="{StaticResource CheckEndTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CheckType}" Value="{x:Static local:QuestEditorCheckType.Start_t}">
                    <Setter TargetName="CheckContent" Property="ContentTemplate" Value="{StaticResource CheckStart_TTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CheckType}" Value="{x:Static local:QuestEditorCheckType.End_t}">
                    <Setter TargetName="CheckContent" Property="ContentTemplate" Value="{StaticResource CheckEnd_TTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CheckType}" Value="{x:Static local:QuestEditorCheckType.Null}">
                    <Setter TargetName="CheckContent" Property="ContentTemplate" Value="{StaticResource CheckNullTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CheckType}" Value="{x:Null}">
                    <Setter TargetName="CheckContent" Property="ContentTemplate" Value="{StaticResource CheckNullTemplate}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource HareCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="62"/>
        </Grid.RowDefinitions>

        <!-- Compact command bar, matching the HaEditor shell. -->
        <Border Grid.Row="0"
                Background="{StaticResource HareSurfaceBrush}"
                BorderBrush="{StaticResource HareBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{local:QuestText QuestEditor_Subtitle}"
                               Foreground="{StaticResource HareMutedTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,12,0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button MinWidth="94"
                            Margin="0,0,8,0"
                            Style="{StaticResource HareButtonStyle}"
                            Click="button_addNewQuest_Click"
                            Content="{local:QuestText QuestEditor_NewQuest}"/>
                    <Button MinWidth="88"
                            Style="{StaticResource HareButtonStyle}"
                            Click="button_importNewQuest_Click"
                            Content="{local:QuestText QuestEditor_Import}"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        Background="{StaticResource HareAccentSoftBrush}"
                        CornerRadius="12">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HareAccentBrush}"
                               Text="{local:QuestText QuestEditor_Eyebrow}"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Quest List -->
            <GroupBox Header="{local:QuestText QuestEditor_QuestLibrary}" Grid.Column="0" Margin="0" FontWeight="Bold">
            <Grid Background="{StaticResource QuestSurfaceBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                            <TextBlock Text="{local:QuestText QuestEditor_Area}"
                               Grid.Column="0" Margin="5,0,0,0"
                               FontWeight="Normal" 
                               VerticalAlignment="Center"/>

                    <ComboBox x:Name="comboBox_questAreaSort" 
                              Grid.Column="1"
                              Margin="10,0,0,4"
                              ItemsSource="{Binding Source={StaticResource QuestAreaCodeTypeEnum}}"  
                              SelectedItem="{Binding SortQuestAreaCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectionChanged="comboBox_questAreaSort_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumNameIntValueConverter}}" FontWeight="Normal" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
                

                <TextBox x:Name="searchBox" Grid.Row="1" Margin="0,0,0,7"
                                 ToolTip="{local:QuestText QuestEditor_FilterTooltip}"
                         TextChanged="SearchBox_TextChanged"/>
                <ListBox x:Name="listbox_Quest" Grid.Row="2" ItemsSource="{Binding FilteredQuests}" Margin="0,0,0,5"
                         SelectionChanged="QuestListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="[" FontWeight="Normal"/>
                                <TextBlock Text="{Binding Id}" FontWeight="Normal"/>
                                <TextBlock Text="]" FontWeight="Normal"/>
                                <TextBlock Margin="5,0,0,0" Text="{Binding Name}" FontWeight="Normal"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid  Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>
                    
                        <Button x:Name="button_addNewQuest" Content="{local:QuestText QuestEditor_NewQuest}" Margin="0,4,4,0"
                        Style="{DynamicResource ButtonStyle_Black}"
                        Click="button_addNewQuest_Click"/>
                        <Button x:Name="button_importNewQuest" Content="{local:QuestText QuestEditor_Import}" Margin="4,4,0,0" Grid.Column="1"
                        Style="{DynamicResource ButtonStyle_Black}"
                            Click="button_importNewQuest_Click"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Quest Editor -->
            <GroupBox Header="{local:QuestText QuestEditor_QuestDetails}" Grid.Column="2" Margin="0" FontWeight="Bold">
            <Grid Background="{StaticResource QuestSurfaceBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0">
                    <!-- Quest Info Tab -->
                        <TabItem Header="{local:QuestText QuestEditor_QuestInfoTab}" FontWeight="Normal">
                        <Grid Background="{StaticResource QuestSurfaceBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Foreground="Gray" Margin="0,0,0,10">The quest <Bold>information</Bold>, such as quest name, parent name.</TextBlock>

                            <ScrollViewer Grid.Row="1"
                                          Background="{StaticResource QuestSurfaceBrush}"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14,10,14,18">
                                    <!-- Quest name -->
                                        <TextBlock Text="{local:QuestText QuestEditor_Name}" FontWeight="Bold"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.Name}"/>

                                    <!-- Parent quest-->
                                        <TextBlock Text="{local:QuestText QuestEditor_ParentQuest}" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="7*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.Parent}" Grid.Column="0"/>
                                                <Button x:Name="button_selectParentFromList" Content="{local:QuestText QuestEditor_Select}"
                                                Grid.Column="2" Margin="5,0,0,0" VerticalAlignment="Top"
                                                Style="{DynamicResource ButtonStyle_Black}"
                                                Click="button_selectParentFromList_Click"
                                                />
                                    </Grid>

                                    <!-- Quest area -->
                                        <TextBlock Text="{local:QuestText QuestEditor_QuestAreaCode}" FontWeight="Bold"/>
                                    <ComboBox x:Name="comboBox_questArea" 
                                              Width="200" HorizontalAlignment="Left"
                                              ItemsSource="{Binding Source={StaticResource QuestAreaCodeTypeEnum}}"  
                                              SelectedItem="{Binding SelectedQuest.Area, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              >
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource enumNameIntValueConverter}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!-- Quest order -->
                                        <TextBlock Text="{local:QuestText QuestEditor_Order}" FontWeight="Bold"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.Order}"/>

                                    <!-- Other boolean properties-->
                                        <CheckBox x:Name="checkbox_blocked" Content="{local:QuestText QuestEditor_Blocked}" FontWeight="Bold" Margin="0,5,0,0" IsChecked="{Binding SelectedQuest.Blocked}"/>
                                        <CheckBox x:Name="checkbox_autoStart" Content="{local:QuestText QuestEditor_AutoStart}" FontWeight="Bold" IsChecked="{Binding SelectedQuest.AutoStart}"/>
                                    <CheckBox x:Name="checkbox_autoPreComplete" Content="{local:QuestText QuestEditor_AutoPreComplete}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.AutoPreComplete}"/>
                                        <CheckBox x:Name="checkbox_autoComplete" Content="{local:QuestText QuestEditor_AutoComplete}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.AutoComplete}"/>
                                    <CheckBox x:Name="checkbox_autoCompleteAction" Content="{local:QuestText QuestEditor_AutoCompleteAction}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.AutoCompleteAction}"/>
                                    <CheckBox x:Name="checkbox_selectedMob" Content="{local:QuestText QuestEditor_SelectedMob}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.SelectedMob}"/>
                                        <CheckBox x:Name="checkbox_autoAccept" Content="{local:QuestText QuestEditor_AutoAccept}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.AutoAccept}"/>
                                        <CheckBox x:Name="checkbox_autoCancel" Content="{local:QuestText QuestEditor_AutoCancel}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.AutoCancel}"/>
                                    <CheckBox x:Name="checkbox_oneShot" Content="{local:QuestText QuestEditor_OneShot}" FontWeight="Bold"  IsChecked="{Binding SelectedQuest.OneShot}"/>

                                    <TextBlock Text="{local:QuestText QuestEditor_ShowLayerTag}" FontWeight="Bold" Margin="0,5,0,0"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.ShowLayerTag}" />

                                    <!-- paddings -->
                                    <Grid Margin="0,0,0,10"/>

                                    <!-- For quest descriptions -->
                                        <TextBlock Text="{local:QuestText QuestEditor_Summary}" FontWeight="Bold"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.Summary}" AcceptsReturn="True" />

                                    <TextBlock Text="{local:QuestText QuestEditor_StartQuestDescription}" FontWeight="Bold"/>
                                    <CheckBox x:Name="checkbox_disableAtStartTab" Content="{local:QuestText QuestEditor_DisableStartTab}" IsChecked="{Binding SelectedQuest.DisableAtStartTab}"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.QuestInfoDesc0}" AcceptsReturn="True" />

                                    <TextBlock Text="{local:QuestText QuestEditor_ActiveQuestDescription}" FontWeight="Bold"/>
                                    <CheckBox x:Name="checkbox_disableAtPerformTab" Content="{local:QuestText QuestEditor_DisablePerformTab}" IsChecked="{Binding SelectedQuest.DisableAtPerformTab}"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.QuestInfoDesc1}" AcceptsReturn="True" />

                                    <TextBlock Text="{local:QuestText QuestEditor_EndQuestDescription}" FontWeight="Bold"/>
                                    <CheckBox x:Name="checkbox_disableAtCompleteTab" Content="{local:QuestText QuestEditor_DisableCompleteTab}"  IsChecked="{Binding SelectedQuest.DisableAtCompleteTab}"/>
                                    <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.QuestInfoDesc2}" AcceptsReturn="True" />

                                    <!-- paddings -->
                                    <Grid Margin="0,0,0,10"/>

                                        <TextBlock Text="{local:QuestText QuestEditor_DemandSummary}" FontWeight="Bold"/>
                                    <Image Source="/Images/Quest/summary_icon.summary.png" Height="15" Stretch="Uniform"  HorizontalAlignment="Left"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="170"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Margin="0,0,0,5" Grid.Column="0" Text="{Binding SelectedQuest.DemandSummary}" AcceptsReturn="True" />
                                                <Button x:Name="button_generateDemandSummary" Grid.Column="1" Content="{local:QuestText QuestEditor_GenerateFromCheck}" Margin="5,0,0,0"
                                                Height="25" VerticalAlignment="Bottom"
                                                Style="{DynamicResource ButtonStyle_DeleteQuest}" Click="button_generateDemandSummary_Click"
                                                />
                                    </Grid>


                                        <TextBlock Text="{local:QuestText QuestEditor_RewardSummary}" FontWeight="Bold"/>
                                    <Image Source="/Images/Quest/QuestIcon.4.0.png" Height="15" Stretch="Uniform" HorizontalAlignment="Left"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="170"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.RewardSummary}" AcceptsReturn="True" />
                                                <Button x:Name="button_generateRewardSummary" Grid.Column="1" Content="{local:QuestText QuestEditor_GenerateFromAct}" Margin="5,0,0,0"
                                                Height="25" VerticalAlignment="Bottom"
                                                Style="{DynamicResource ButtonStyle_DeleteQuest}" Click="button_generateRewardSummary_Click"
                                                />
                                    </Grid>

                                    <!-- paddings -->
                                    <Grid Margin="0,0,0,10"/>

                                    <!-- For medals -->
                                    <TextBlock Text="{local:QuestText QuestEditor_MiscProperties}" TextDecorations="Underline" FontWeight="Bold"/>
                                    <CheckBox x:Name="checkbox_isMedal" Content="{local:QuestText QuestEditor_Medal}" FontWeight="Bold" Margin="0,5,0,0" IsChecked="{Binding SelectedQuest.IsMedal}"/>
                                    <StackPanel Margin="20,0,0,0" 
                                                Visibility="{Binding SelectedQuest.IsMedal, Mode=TwoWay, Converter={StaticResource booleanToVisibility2Converter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{local:QuestText QuestEditor_MedalCategory}"/>
                                            <ComboBox 
                                                ItemsSource="{Binding Source={StaticResource QuestMedalTypeEnum}}"  
                                                SelectedValue="{Binding SelectedQuest.MedalCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectedValuePath="."
                                                Margin="20,0,0,0" Width="100">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource enumNameIntValueConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="{local:QuestText QuestEditor_ViewMedalItem}"/>
                                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Top">
                                                <TextBlock Text="["/>
                                                <TextBlock Text="{Binding SelectedQuest.ViewMedalItem, Converter={StaticResource itemIdToItemNameConverter}}" FontWeight="Bold" Margin="2,0,0,0"/>
                                                <TextBlock Text="]" Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="8*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBox Margin="0,0,0,5" Text="{Binding SelectedQuest.ViewMedalItem}" Grid.Column="0"/>
                            <Button x:Name="button_selectmedalItem" Content="{local:QuestText QuestEditor_Select}"
                                                Grid.Column="2" Margin="5,0,0,0" VerticalAlignment="Top"
                                                Style="{DynamicResource ButtonStyle_Black}"
                                                    Click="button_selectmedalItem_Click"
                                                />
                                        </Grid>

                                    </StackPanel>

                                    <!-- bottom padding-->
                                    <Grid Margin="0,0,0,30"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Say Info Tab -->
                        <TabItem Header="{local:QuestText QuestEditor_SayInfoTab}"  FontWeight="Normal">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TabControl Grid.Row="0">
                                    <!-- Start quest-->
                                    <TabItem Header="{local:QuestText QuestEditor_StartConversation}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Margin="0,0,0,10" Text="{local:QuestText QuestEditor_ConversationHelp}" Foreground="Gray"/>

                                            <ContentControl x:Name="dataGrid_ConversationStart" Grid.Row="1" 
                                                            ContentTemplate="{StaticResource ConversationDataGridTemplate}" 
                                                            Content="{Binding SelectedQuest.SayInfoStartQuest}">
                                            </ContentControl>
                                        </Grid>
                                    </TabItem>

                                    <!-- End quest-->
                                    <TabItem Header="{local:QuestText QuestEditor_EndConversation}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Margin="0,0,0,10" Text="{local:QuestText QuestEditor_ConversationHelp}" Foreground="Gray"/>

                                            <ContentControl x:Name="DataGrid_conversationEndQuest" Grid.Row="1"
                                                            ContentTemplate="{StaticResource ConversationDataGridTemplate}" 
                                                            Content="{Binding SelectedQuest.SayInfoEndQuest}">
                                            </ContentControl>
                                        </Grid>
                                    </TabItem>

                                    <!-- "stop", start quest info -->
                                    <TabItem Header="{local:QuestText QuestEditor_StopStartConversation}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Margin="0,0,0,10" Text="{local:QuestText QuestEditor_ConditionHelp}" Foreground="Gray"/>

                                            <ContentControl x:Name="DataGrid_conversationStopStartQuest" Grid.Row="1"
                                                            ContentTemplate="{StaticResource StopConversationDataGridTemplate}" 
                                                            Content="{Binding SelectedQuest.SayInfoStop_StartQuest}">
                                            </ContentControl>
                                        </Grid>
                                    </TabItem>

                                    <!-- "stop", start quest info -->
                                    <TabItem Header="{local:QuestText QuestEditor_StopEndConversation}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Margin="0,0,0,10" Text="{local:QuestText QuestEditor_ConditionHelp}" Foreground="Gray"/>

                                            <ContentControl x:Name="DataGrid_conversationStopEndQuest" Grid.Row="1"
                                                            ContentTemplate="{StaticResource StopConversationDataGridTemplate}" 
                                                            Content="{Binding SelectedQuest.SayInfoStop_EndQuest}">
                                            </ContentControl>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                    </TabItem>

                    <!-- Check Conditions Tab -->
                        <TabItem Header="{local:QuestText QuestEditor_CheckConditionsTab}" FontWeight="Normal" >
                        <Grid>
                            <ScrollViewer>
                                <TabControl Grid.Row="1">
                                    <!-- Start quest-->
                                    <TabItem Header="{local:QuestText QuestEditor_StartCheck}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Margin="0,0,0,5" Foreground="Gray">The actions to be <Bold>checked</Bold> when starting the quest. (i.e: requirements)</TextBlock>

                                            <DataGrid x:Name="DataGrid_checkStartQuest" Grid.Row="1" 
                                                      ItemsSource="{Binding SelectedQuest.CheckStartInfo}"
                                                      IsReadOnly="False"
                                                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True">
                                                <DataGrid.Columns>
                                                    <!-- Conversation Type Column -->
                                        <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Type}" Width="170">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox Style="{StaticResource QuestDataGridComboBoxStyle}"
                                                                          SelectedItem="{Binding CheckType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding Source={StaticResource CheckTypeEnum}}"
                                                                          VerticalAlignment="Center">
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- Rewards Column -->
                                                    <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Rewards}" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <StaticResource ResourceKey="CheckRewardsColumnTemplate"/>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </TabItem>

                                    <!-- End quest-->
                                    <TabItem Header="{local:QuestText QuestEditor_EndCheck}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Margin="0,0,0,5" Foreground="Gray">The actions to be <Bold>checked</Bold> when completing the quest. (i.e: requirements)</TextBlock>

                                            <DataGrid x:Name="DataGrid_checkEndQuest" Grid.Row="1" 
                                                      ItemsSource="{Binding SelectedQuest.CheckEndInfo}"
                                                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True">
                                                <DataGrid.Columns>
                                                    <!-- Conversation Type Column -->
                                        <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Type}" Width="170">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox Style="{StaticResource QuestDataGridComboBoxStyle}"
                                                                          SelectedItem="{Binding CheckType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding Source={StaticResource CheckTypeEnum}}"
                                                                          VerticalAlignment="Center">
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- Rewards Column -->
                                                    <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Rewards}" Width="3*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <StaticResource ResourceKey="CheckRewardsColumnTemplate"/>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </TabItem>

                                </TabControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Act Requirements Tab -->
                        <TabItem Header="{local:QuestText QuestEditor_ActRequirementsTab}" FontWeight="Normal">
                        <Grid>
                            <ScrollViewer>

                                <TabControl Grid.Row="1">
                                    <!-- Start quest-->
                                    <TabItem Header="{local:QuestText QuestEditor_StartAction}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Foreground="Gray" Margin="0,0,0,5">The actions to be <Bold>given</Bold> when starting the quest. (i.e: give quest item, give rewards)</TextBlock>

                                            <DataGrid x:Name="DataGrid_actStartQuest" Grid.Row="1" 
                                                      ItemsSource="{Binding SelectedQuest.ActStartInfo}"
                                                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True">
                                                <DataGrid.Columns>
                                                    <!-- Conversation Type Column -->
                                        <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Type}" Width="170">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox Style="{StaticResource QuestDataGridComboBoxStyle}"
                                                                          SelectedItem="{Binding ActType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding Source={StaticResource ActTypeEnum}}"
                                                                          VerticalAlignment="Center">
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- Rewards Column -->
                                                    <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Rewards}" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <StaticResource ResourceKey="ActRewardsColumnTemplate"/>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </TabItem>

                                    <!-- End quest-->
                                    <TabItem Header="{local:QuestText QuestEditor_EndAction}" FontWeight="Normal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Foreground="Gray" Margin="0,0,0,5">The actions to be <Bold>given</Bold> when completing the quest. (i.e: give quest item, give rewards)</TextBlock>

                                            <DataGrid x:Name="DataGrid_actEndQuest" Grid.Row="1" 
                                                          ItemsSource="{Binding SelectedQuest.ActEndInfo}"
                                                          AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True">
                                                <DataGrid.Columns>
                                                    <!-- Conversation Type Column -->
                                        <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Type}" Width="170">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox Style="{StaticResource QuestDataGridComboBoxStyle}"
                                                                          SelectedItem="{Binding ActType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              ItemsSource="{Binding Source={StaticResource ActTypeEnum}}"
                                                                              VerticalAlignment="Center">
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- Rewards Column -->
                                                    <DataGridTemplateColumn Header="{local:QuestText QuestEditor_Rewards}" Width="3*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <StaticResource ResourceKey="ActRewardsColumnTemplate"/>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </TabItem>

                                </TabControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>

            </Grid>
        </GroupBox>

        <!-- Quick inspector for the fields used most often while editing conversations and conditions. -->
        <GroupBox Grid.Column="4"
                  Margin="0"
                  FontWeight="Bold"
                  Header="{local:QuestText QuestEditor_QuestInfoTab}">
            <ScrollViewer Background="{StaticResource QuestSurfaceBrush}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="2,0,2,12">
                    <TextBlock Margin="0,0,0,4"
                               Style="{StaticResource HareSectionTitleStyle}"
                               Text="{local:QuestText QuestEditor_QuestDetails}"/>

                    <TextBlock Text="{local:QuestText QuestEditor_QuestIdLabel}"/>
                    <TextBox IsReadOnly="True" Text="{Binding SelectedQuest.Id}"/>

                    <TextBlock Text="{local:QuestText QuestEditor_Name}"/>
                    <TextBox Text="{Binding SelectedQuest.Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="{local:QuestText QuestEditor_ParentQuest}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SelectedQuest.Parent, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1"
                                Width="36"
                                Margin="8,2,0,6"
                                Style="{StaticResource HareIconButtonStyle}"
                                ToolTip="{local:QuestText QuestEditor_Select}"
                                AutomationProperties.Name="{local:QuestText QuestEditor_Select}"
                                Click="button_selectParentFromList_Click"
                                Content="..."/>
                    </Grid>

                    <TextBlock Text="{local:QuestText QuestEditor_QuestAreaCode}"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource QuestAreaCodeTypeEnum}}"
                              SelectedItem="{Binding SelectedQuest.Area, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumNameIntValueConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{local:QuestText QuestEditor_Order}"/>
                    <TextBox InputScope="Number" Text="{Binding SelectedQuest.Order, UpdateSourceTrigger=PropertyChanged}"/>

                    <Separator Margin="0,10"/>
                    <TextBlock Margin="0,0,0,4"
                               Style="{StaticResource HareSectionTitleStyle}"
                               Text="{local:QuestText QuestEditor_MiscProperties}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_Blocked}" IsChecked="{Binding SelectedQuest.Blocked}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_AutoStart}" IsChecked="{Binding SelectedQuest.AutoStart}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_AutoPreComplete}" IsChecked="{Binding SelectedQuest.AutoPreComplete}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_AutoComplete}" IsChecked="{Binding SelectedQuest.AutoComplete}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_AutoCompleteAction}" IsChecked="{Binding SelectedQuest.AutoCompleteAction}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_SelectedMob}" IsChecked="{Binding SelectedQuest.SelectedMob}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_AutoAccept}" IsChecked="{Binding SelectedQuest.AutoAccept}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_AutoCancel}" IsChecked="{Binding SelectedQuest.AutoCancel}"/>
                    <CheckBox Content="{local:QuestText QuestEditor_OneShot}" IsChecked="{Binding SelectedQuest.OneShot}"/>

                    <Separator Margin="0,10"/>
                    <TextBlock Text="{local:QuestText QuestEditor_ShowLayerTag}"/>
                    <TextBox Text="{Binding SelectedQuest.ShowLayerTag, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
        </Grid>

        <!-- Persistent selection state and local actions. -->
        <Border Grid.Row="2"
                Background="{StaticResource HareSurfaceBrush}"
                BorderBrush="{StaticResource HareBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource HareSuccessBrush}"/>
                    <TextBlock Margin="8,0,0,0"
                               Foreground="{StaticResource HareMutedTextBrush}"
                               Text="{local:QuestText QuestEditor_QuestDetails}"/>
                    <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Text="{Binding SelectedQuest.Id}"/>
                    <TextBlock Margin="4,0,0,0" FontWeight="SemiBold" Text="-"/>
                    <TextBlock Margin="4,0,0,0"
                               MaxWidth="360"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding SelectedQuest.Name}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="button_exportQuest"
                            Width="110"
                            Content="{local:QuestText QuestEditor_Export}"
                            Style="{StaticResource HareButtonStyle}"
                            Click="button_exportQuest_Click"/>
                    <Button x:Name="button_deleteQuest"
                            Width="110"
                            Margin="8,0,0,0"
                            Content="{local:QuestText QuestEditor_Delete}"
                            Style="{StaticResource HareDangerButtonStyle}"
                            Click="button_deleteQuest_Click"/>
                    <Button x:Name="button_saveQuest"
                            Width="130"
                            Margin="8,0,0,0"
                            Content="{local:QuestText QuestEditor_SaveChanges}"
                            Style="{StaticResource HarePrimaryButtonStyle}"
                            Click="button_saveQuest_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
