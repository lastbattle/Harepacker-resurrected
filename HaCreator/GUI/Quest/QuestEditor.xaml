                                    <RowDefinition Height="Auto" MinHeight="38"/>
                                    <RowDefinition Height="Auto" MinHeight="38"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="150" Width="3*"/>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="20" />
