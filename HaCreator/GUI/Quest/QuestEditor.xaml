                                               VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="40" 
                                             InputScope="Number"
                                             />
                                </StackPanel>
                                
                                <!-- Potential, prop, gender -->
                                <WrapPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
