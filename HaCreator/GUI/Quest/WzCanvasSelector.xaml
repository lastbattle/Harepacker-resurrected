<Window x:Class="HaCreator.GUI.Quest.WzCanvasSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select WZ image"
        Width="900"
        Height="620"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        FontFamily="Segoe UI"
        FontSize="12"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Category" Margin="0,0,0,3" FontWeight="SemiBold"/>
                <ComboBox x:Name="CategoryCombo"
                          Height="29"
                          SelectionChanged="CategoryCombo_SelectionChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="IMG file" Margin="0,0,0,3" FontWeight="SemiBold"/>
                <ComboBox x:Name="ImageCombo"
                          Height="29"
                          IsEditable="True"
                          IsTextSearchEnabled="True"/>
            </StackPanel>

            <Button Grid.Column="3"
                    Margin="8,20,0,0"
                    Padding="14,4"
                    Content="Load image"
                    Click="LoadImage_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2*" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#CBD3DE"
                    BorderThickness="1"
                    CornerRadius="4">
                <TreeView x:Name="PropertyTree"
                          Margin="4"
                          SelectedItemChanged="PropertyTree_SelectedItemChanged"/>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#CBD3DE"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Canvas preview" FontWeight="SemiBold"/>
                    <Border Grid.Row="1"
                            Margin="0,8"
                            Background="#EEF1F5"
                            BorderBrush="#D8DEE8"
                            BorderThickness="1">
                        <Image x:Name="CanvasPreview"
                               Margin="8"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                    <TextBlock x:Name="CanvasInfoText"
                               Grid.Row="2"
                               Foreground="#667085"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Selected markup path" FontWeight="SemiBold"/>
                <TextBox x:Name="SelectedPathText"
                         Margin="0,3,8,0"
                         Padding="7,4"
                         IsReadOnly="True"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Width="90"
                    Height="31"
                    Margin="0,18,6,0"
                    Content="Cancel"
                    Click="Cancel_Click"/>
            <Button x:Name="SelectButton"
                    Grid.Column="2"
                    Width="100"
                    Height="31"
                    Margin="0,18,0,0"
                    Content="Select image"
                    IsEnabled="False"
                    IsDefault="True"
                    Click="Select_Click"/>
        </Grid>
    </Grid>
</Window>
