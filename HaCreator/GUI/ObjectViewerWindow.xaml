<Window x:Class="HaCreator.GUI.ObjectViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        xmlns:editorItems="clr-namespace:HaCreator.GUI.EditorPanels"
        Title="{dialogLoc:DialogText Dialog_Map_hierarchy_E5070B}"
        Height="680"
        Width="380"
        MinHeight="300"
        MinWidth="250"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Topmost="False"
        Background="{DynamicResource HareCanvasBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="10" Background="{StaticResource HareSurfaceBrush}" BorderBrush="{StaticResource HareBorderBrush}" BorderThickness="1" CornerRadius="7">
        <Border x:Name="objectViewerPanelHost" Margin="1">
            <editorItems:ObjectViewerPanel x:Name="objectViewerPanel"/>
        </Border>
    </Border>
</Window>
