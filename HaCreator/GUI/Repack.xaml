<Window x:Class="HaCreator.GUI.Repack" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
 Title="{dialogLoc:DialogText Dialog_Repack_WZ_files_FE4AEF}" Width="560" Height="470" MinHeight="360" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI" Closing="Repack_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource HareToolbarStyle}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Choose_which_modified_archives_to_write_B53E60}" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="20" Style="{StaticResource HareCardStyle}">
            <ListBox x:Name="filesList"/>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="stateText" VerticalAlignment="Center" Text="{dialogLoc:DialogText Dialog_Ready_5FA7AA}"/>
                <Button Grid.Column="1" MinWidth="88" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
                <Button x:Name="repackButton" Grid.Column="2" Margin="8,0,0,0" MinWidth="100" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="Repack_Click" Content="{dialogLoc:DialogText Dialog_Repack_8D3E09}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
