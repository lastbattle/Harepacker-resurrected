<Window x:Class="HaCreator.GUI.HaEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        
        xmlns:local="clr-namespace:HaCreator.GUI"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization"
        xmlns:customControls="clr-namespace:HaCreator.CustomControls"
        xmlns:editorItems="clr-namespace:HaCreator.GUI.EditorPanels"
        xmlns:mapEditor="clr-namespace:HaCreator.MapEditor"

        mc:Ignorable="d" 
        d:DesignHeight="721" d:DesignWidth="1111" 
        
        MouseWheel="OnMouseWheel" 
        Closing="HaEditor2_Closing" 
        SizeChanged="WindowSizeChanged" Title="{loc:Loc Editor_HaCreator_resurrected_8AD585}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:HaEditor.New}" CanExecute="AlwaysExecute" Executed="New_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Open}" CanExecute="AlwaysExecute" Executed="Open_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Export}" CanExecute="AlwaysExecute" Executed="Export_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Save}" CanExecute="AlwaysExecute" Executed="Save_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Repack}" CanExecute="AlwaysExecute" Executed="Repack_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.About}" CanExecute="AlwaysExecute" Executed="About_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Help}" CanExecute="AlwaysExecute" Executed="Help_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Settings}" CanExecute="AlwaysExecute" Executed="Settings_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Exit}" CanExecute="AlwaysExecute" Executed="Exit_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Minimap}" CanExecute="AlwaysExecute" Executed="Minimap_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Parallax}" CanExecute="AlwaysExecute" Executed="Parallax_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Finalize}" CanExecute="AlwaysExecute" Executed="Finalize_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.MapSim}" CanExecute="AlwaysExecute" Executed="MapSim_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.RegenMinimap}" CanExecute="HasMinimap" Executed="RegenMinimap_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Snapping}" CanExecute="AlwaysExecute" Executed="Snapping_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.Random}" CanExecute="AlwaysExecute" Executed="Random_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.InfoMode}" CanExecute="AlwaysExecute" Executed="InfoMode_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.AnimateMapObjectPreviews}" CanExecute="AlwaysExecute" Executed="AnimateMapObjectPreviews_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.HaRepacker}" CanExecute="AlwaysExecute" Executed="HaRepacker_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.NewPlatform}" CanExecute="AlwaysExecute" Executed="NewPlatform_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.UserObjs}" CanExecute="AlwaysExecute" Executed="UserObjs_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.PhysicsEdit}" CanExecute="AlwaysExecute" Executed="PhysicsEdit_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.ShowQuestEditorWindow}" CanExecute="AlwaysExecute" Executed="ShowQuestEditorWindow_Executed"/>
        <CommandBinding Command="{x:Static local:HaEditor.ShowMapProperties}" CanExecute="AlwaysExecute" Executed="ShowMapProperties_Executed"/>
    </Window.CommandBindings>

    <Window.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="ChromeBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="DividerBrush" Color="#DCE3EC"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>

        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF2F7"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D7DEE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryCommandButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding Background}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1E40AF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolRailButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome" CornerRadius="6" Background="{TemplateBinding Background}">
                            <Grid>
                                <Border x:Name="SelectionMarker"
                                        Width="3" Height="22"
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="0,2,2,0"
                                        Background="Transparent"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF2F7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter TargetName="SelectionMarker" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocumentTabItemStyle" TargetType="TabItem">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Chrome" Margin="0,4,3,0" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Chrome" Property="Background" Value="White"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabItemStyle" TargetType="TabItem">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="7,8"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border x:Name="Marker" Height="3" Margin="7,0" VerticalAlignment="Bottom"
                                    Background="Transparent" CornerRadius="2,2,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Marker" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTabItemStyle" TargetType="TabItem">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Chrome" Margin="1" Padding="{TemplateBinding Padding}"
                                CornerRadius="5" Background="{TemplateBinding Background}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AssetExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ToggleButton x:Name="HeaderSite" Padding="10,0" HorizontalContentAlignment="Stretch"
                                              Background="Transparent" BorderThickness="0"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter ContentSource="Content" RecognizesAccessKey="True"
                                                          Content="{TemplateBinding Header}" VerticalAlignment="Center"/>
                                        <Path x:Name="Chevron" Grid.Column="1" Width="10" Height="6" Stretch="Fill"
                                              Stroke="#64748B" StrokeThickness="1.6" Data="M1,1 L5,5 L9,1"/>
                                    </Grid>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite" Grid.Row="1" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Chevron" Property="Data" Value="M1,5 L5,1 L9,5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource HareCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="52"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <!-- Compact command bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="4"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0" Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Header="{loc:Loc Editor_File_50009C}">
                        <MenuItem Header="{loc:Loc Editor_New_18FDD5}" Command="{x:Static local:HaEditor.New}" InputGestureText="Ctrl+N"/>
                        <MenuItem Header="{loc:Loc Editor_Open_map_03863A}" Command="{x:Static local:HaEditor.Open}" InputGestureText="Ctrl+O"/>
                        <MenuItem Header="{loc:Loc Editor_Save_map_1EA04E}" Command="{x:Static local:HaEditor.Export}" InputGestureText="Ctrl+S"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Editor_Save_to_WZ_CDEA60}" Command="{x:Static local:HaEditor.Save}"/>
                        <MenuItem Header="{loc:Loc Editor_Repack_WZ_files_90BFA4}" Command="{x:Static local:HaEditor.Repack}"/>
                        <MenuItem Header="{loc:Loc Editor_Open_HaRepacker_09E8F1}" Command="{x:Static local:HaEditor.HaRepacker}"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Editor_Exit_D17D84}" Command="{x:Static local:HaEditor.Exit}"/>
                    </MenuItem>
                    <MenuItem Header="{loc:Loc Editor_View_DCC839}">
                        <MenuItem Header="{loc:Loc Editor_Map_browser_5ADA56}" Click="ShowMapBrowser_Click"/>
                        <MenuItem Header="{loc:Loc Editor_Assets_BD1273}" Click="ShowAssets_Click"/>
                        <MenuItem Header="{loc:Loc Editor_Hierarchy_23BE56}" Click="ShowHierarchy_Click"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Editor_Toggle_minimap_357182}" Command="{x:Static local:HaEditor.Minimap}"/>
                        <MenuItem Header="{loc:Loc Editor_Toggle_snapping_13C561}" Command="{x:Static local:HaEditor.Snapping}"/>
                        <MenuItem Header="{loc:Loc Editor_Random_Tiles_1ED7F5}" Command="{x:Static local:HaEditor.Random}"/>
                        <MenuItem Header="{loc:Loc Editor_Parallax_backgrounds_69E70D}" Command="{x:Static local:HaEditor.Parallax}"/>
                        <MenuItem Header="{loc:Loc Editor_Information_overlays_1CC00F}" Command="{x:Static local:HaEditor.InfoMode}"/>
                        <MenuItem Header="{loc:Loc Editor_Animate_asset_previews_E74DF1}" Command="{x:Static local:HaEditor.AnimateMapObjectPreviews}"/>
                    </MenuItem>
                    <MenuItem Header="{loc:Loc Editor_Map_BE176B}">
                        <MenuItem Header="{loc:Loc Editor_Preview_324B13}" Command="{x:Static local:HaEditor.MapSim}"/>
                        <MenuItem Header="{loc:Loc Editor_Validate_current_map_3137EC}" Click="ValidateCurrentMap_Click"/>
                        <MenuItem Header="{loc:Loc Editor_Validate_all_maps_7F88A7}" Click="MapExplorerCheckMapButton_Click"/>
                        <MenuItem Header="{loc:Loc Editor_Finalize_Footholds_68717E}" Command="{x:Static local:HaEditor.Finalize}"/>
                        <MenuItem Header="{loc:Loc Editor_Regenerate_Minimap_CD2C30}" Command="{x:Static local:HaEditor.RegenMinimap}"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Editor_Map_properties_EC4B13}" Command="{x:Static local:HaEditor.ShowMapProperties}"/>
                        <MenuItem Header="{loc:Loc Editor_New_platform_D53525}" Command="{x:Static local:HaEditor.NewPlatform}"/>
                        <MenuItem Header="{loc:Loc Editor_Quest_editor_A8BFA2}" Command="{x:Static local:HaEditor.ShowQuestEditorWindow}"/>
                    </MenuItem>
                    <MenuItem Header="{loc:Loc Editor_Tools_EA93D6}">
                        <MenuItem Header="{loc:Loc Editor_Settings_74A883}" Command="{x:Static local:HaEditor.Settings}"/>
                        <MenuItem Header="{loc:Loc Editor_Map_Physics_61AD90}" Command="{x:Static local:HaEditor.PhysicsEdit}"/>
                        <MenuItem Header="{loc:Loc Editor_Manage_User_Objects_455E55}" Command="{x:Static local:HaEditor.UserObjs}"/>
                        <MenuItem Header="{loc:Loc Editor_Quest_editor_B81784}" Command="{x:Static local:HaEditor.ShowQuestEditorWindow}"/>
                    </MenuItem>
                    <MenuItem Header="{loc:Loc Editor_Help_B79CAC}">
                        <MenuItem Header="{loc:Loc Editor_Help_B79CAC}" Command="{x:Static local:HaEditor.Help}"/>
                        <MenuItem Header="{loc:Loc Editor_About_HaCreator_D7275A}" Command="{x:Static local:HaEditor.About}"/>
                    </MenuItem>
                </Menu>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource CommandButtonStyle}" Click="Undo_Click" ToolTip="{loc:Loc Editor_Undo_Ctrl_Z_A67232}" AutomationProperties.Name="Undo">
                        <TextBlock FontFamily="Segoe UI Symbol" FontSize="18" Text="↶"/>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Click="Redo_Click" ToolTip="{loc:Loc Editor_Redo_Ctrl_Y_323109}" AutomationProperties.Name="Redo">
                        <TextBlock FontFamily="Segoe UI Symbol" FontSize="18" Text="↷"/>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}"
                            Command="{x:Static local:HaEditor.Export}"
                            ToolTip="{loc:Loc Editor_Save_map_Ctrl_S_1E254B}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe UI Symbol" FontSize="16" Text="▣"/>
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="{loc:Loc Editor_Save_1509F5}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="2" Margin="18,0" VerticalAlignment="Center" Background="#EEF2F7" CornerRadius="5" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{loc:Loc Editor_Current_map_A6E14D}"/>
                        <TextBlock Margin="8,0,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   Text="{Binding SelectedItem.Header, ElementName=tabControl1, FallbackValue=No map loaded}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource CommandButtonStyle}"
                            Command="{x:Static local:HaEditor.ShowQuestEditorWindow}"
                            ToolTip="{loc:Loc Editor_Open_Quest_Editor_C0AFD3}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="15" Text="▤"/>
                            <TextBlock Margin="7,0,0,0" Text="{loc:Loc Editor_Quests_60D40D}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Click="ShowMapBrowser_Click" ToolTip="{loc:Loc Editor_Search_maps_and_commands_FF74F6}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE721;"/>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Click="ValidateCurrentMap_Click" ToolTip="{loc:Loc Editor_Validate_the_active_map_only_07B633}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE73E;"/>
                            <TextBlock Margin="7,0,0,0" Text="{loc:Loc Editor_Validate_40611A}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryCommandButtonStyle}"
                            Command="{x:Static local:HaEditor.MapSim}"
                            ToolTip="{loc:Loc Editor_Preview_map_E19CEF}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" Text="▶"/>
                            <TextBlock Margin="7,0,0,0" Text="{loc:Loc Editor_Preview_324B13}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editing tool rail -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#F8FAFC"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,6">
                <RadioButton x:Name="selectionToolRadioButton" GroupName="EditorTools" IsChecked="True" Tag="Select" Checked="EditorTool_Checked"
                             Style="{StaticResource ToolRailButtonStyle}" ToolTip="{loc:Loc Editor_Select_S_B368AF}">
                    <Path Width="17" Height="20" Stretch="Fill" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Data="M2,1 L2,17 L6.4,13.2 L9.5,20 L12.1,18.8 L9,12.2 L15,12 Z"/>
                </RadioButton>
                <RadioButton GroupName="EditorTools" Tag="Tile" Checked="EditorTool_Checked"
                             Style="{StaticResource ToolRailButtonStyle}" ToolTip="{loc:Loc Editor_Tiles_T_FE4E53}">
                    <Grid Width="19" Height="19">
                        <Rectangle Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7"/>
                        <Rectangle Width="1.7" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                        <Rectangle Height="1.7" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    </Grid>
                </RadioButton>
                <RadioButton GroupName="EditorTools" Tag="Object" Checked="EditorTool_Checked"
                             Style="{StaticResource ToolRailButtonStyle}" ToolTip="{loc:Loc Editor_Objects_O_F1F32A}">
                    <Path Width="20" Height="20" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7"
                          Data="M10,1 L19,6 L19,15 L10,20 L1,15 L1,6 Z M1,6 L10,11 L19,6 M10,11 L10,20"/>
                </RadioButton>
                <RadioButton GroupName="EditorTools" Tag="Life" Checked="EditorTool_Checked"
                             Style="{StaticResource ToolRailButtonStyle}" ToolTip="{loc:Loc Editor_NPCs_and_mobs_N_9A06FB}">
                    <Path Width="18" Height="20" Stretch="Fill" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Data="M9,1 A4,4 0 1 1 8.9,1 M2,20 C2,14 4.5,11 9,11 C13.5,11 16,14 16,20 Z"/>
                </RadioButton>
                <RadioButton GroupName="EditorTools" Tag="Portal" Checked="EditorTool_Checked"
                             Style="{StaticResource ToolRailButtonStyle}" ToolTip="{loc:Loc Editor_Portals_P_67398E}">
                    <Path Width="20" Height="20" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2"
                          Data="M10,1 A9,9 0 1 1 9.9,1 M10,6 A4,4 0 1 1 9.9,6"/>
                </RadioButton>
                <RadioButton GroupName="EditorTools" Tag="Foothold" Checked="EditorTool_Checked"
                             Style="{StaticResource ToolRailButtonStyle}" ToolTip="{loc:Loc Editor_Draw_footholds_91FC09}">
                    <Path Width="21" Height="18" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2"
                          Data="M1,15 L6,9 L11,13 L20,3 M4,17 L18,17"/>
                </RadioButton>
                <RadioButton GroupName="EditorTools" Tag="Rope" Checked="EditorTool_Checked"
