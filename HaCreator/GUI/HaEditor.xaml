<Window x:Class="HaCreator.GUI.HaEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        
        xmlns:local="clr-namespace:HaCreator.GUI"
        xmlns:customControls="clr-namespace:HaCreator.CustomControls"
        xmlns:editorItems="clr-namespace:HaCreator.GUI.EditorPanels"
        xmlns:mapEditor="clr-namespace:HaCreator.MapEditor"

        mc:Ignorable="d" 
        d:DesignHeight="721" d:DesignWidth="1111" 
        
        MouseWheel="OnMouseWheel" 
        Closing="HaEditor2_Closing" 
        SizeChanged="WindowSizeChanged" Title="HaCreator resurrected">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <local:HaRibbon x:Name="ribbon"
                        Grid.Row="0" Grid.ColumnSpan="3"/>

        <!-- editor board-->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TabControl x:Name="tabControl1" Grid.Row="0"
                       SelectionChanged="tabControl1_SelectionChanged"
                        >

            </TabControl>
            <mapEditor:MultiBoard x:Name="multiBoard" Grid.Row="1"/>
        </Grid>


        <!-- Side panel -->
        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#FFE5E5E5"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"/>

        <Grid x:Name="toolWindowsPanel"
              Grid.Row="1"
              Grid.Column="2">
            <TabControl x:Name="toolWindowsTabControl"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        SelectionChanged="ToolWindowsTabControl_SelectionChanged">
                <TabItem x:Name="mapExplorerTabItem"
                         Header="Map Explorer"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <TabItem.Resources>
                        <Style x:Key="MapExplorerButton" TargetType="{x:Type Button}">
                            <Setter Property="Height" Value="26"/>
                            <Setter Property="MinWidth" Value="72"/>
                            <Setter Property="Padding" Value="8,2"/>
                        </Style>
                        <Style x:Key="MapExplorerTextBox" TargetType="{x:Type TextBox}">
                            <Setter Property="Height" Value="26"/>
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                        <Style x:Key="MapExplorerStatusText" TargetType="{x:Type TextBlock}">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="MaxHeight" Value="48"/>
                        </Style>
                    </TabItem.Resources>
                    <Grid x:Name="mapExplorerLayoutGrid"
                          Margin="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TabControl x:Name="mapExplorerSourceTabControl"
                                    Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    SelectionChanged="MapExplorerSourceTabControl_SelectionChanged">
                            <TabItem x:Name="mapExplorerWzTabItem"
                                     Header="WZ"
                                     HorizontalContentAlignment="Stretch"
                                     VerticalContentAlignment="Stretch">
                                <DockPanel Margin="0,8,0,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           LastChildFill="True">
                                    <TextBox x:Name="mapExplorerSearchTextBox"
                                             DockPanel.Dock="Top"
                                             Margin="0,0,0,6"
                                             Style="{StaticResource MapExplorerTextBox}"
                                             TextChanged="MapExplorerSearchTextBox_TextChanged"
                                             ToolTip="Search maps"/>

                                    <DockPanel x:Name="mapExplorerFilterPanel"
                                               DockPanel.Dock="Top"
                                               Margin="0,0,0,6"
                                               LastChildFill="False">
                                        <CheckBox x:Name="mapExplorerTownOnlyCheckBox"
                                                  VerticalAlignment="Center"
                                                  DockPanel.Dock="Left"
                                                  Content="Town only"
                                                  Checked="MapExplorerTownOnlyCheckBox_Changed"
                                                  Unchecked="MapExplorerTownOnlyCheckBox_Changed"/>
                                    </DockPanel>

                                    <customControls:MapBrowserWpf x:Name="mapExplorerBrowser"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Stretch"/>
                                </DockPanel>
                            </TabItem>

                            <TabItem x:Name="mapExplorerHistoryTabItem"
                                     Header="History"
                                     HorizontalContentAlignment="Stretch"
                                     VerticalContentAlignment="Stretch">
                                <DockPanel Margin="0,8,0,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           LastChildFill="True">
                                    <Grid x:Name="mapExplorerHistoryButtonsGrid"
                                          DockPanel.Dock="Bottom"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="mapExplorerClearHistoryButton"
                                                Grid.Column="1"
                                                Width="88"
                                                Style="{StaticResource MapExplorerButton}"
                                                Click="MapExplorerClearHistoryButton_Click"
                                                Content="Clear"/>
                                        <Button x:Name="mapExplorerDeleteHistoryButton"
                                                Grid.Column="2"
                                                Width="88"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource MapExplorerButton}"
                                                Click="MapExplorerDeleteHistoryButton_Click"
                                                Content="Delete"
                                                IsEnabled="False"/>
                                    </Grid>

                                    <customControls:MapBrowserWpf x:Name="mapExplorerHistoryBrowser"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Stretch"
                                                                  IsHistoryMapBrowser="True"
                                                                  PreviewPanelVisible="False"/>
                                </DockPanel>
                            </TabItem>

                            <TabItem x:Name="mapExplorerHamTabItem" Header="HAM">
                                <Grid Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="mapExplorerHamPathTextBox"
                                                 Grid.Column="0"
                                                 Margin="0,0,8,0"
                                                 Style="{StaticResource MapExplorerTextBox}"
                                                 TextChanged="MapExplorerHamPathTextBox_TextChanged"/>
                                        <Button x:Name="mapExplorerBrowseHamButton"
                                                Grid.Column="1"
                                                Width="72"
                                                Style="{StaticResource MapExplorerButton}"
                                                Click="MapExplorerBrowseHamButton_Click"
                                                Content="Browse"/>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,8,0,0"
                                            Padding="8"
                                            BorderBrush="#FFD0D0D0"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8">
                                        <TextBlock Text="{Binding Text, ElementName=mapExplorerHamPathTextBox}"
                                                   Style="{StaticResource MapExplorerStatusText}"
                                                   ToolTip="{Binding Text, ElementName=mapExplorerHamPathTextBox}"/>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="mapExplorerXmlTabItem" Header="XML">
                                <Grid Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="mapExplorerXmlPathTextBox"
                                                 Grid.Column="0"
                                                 Margin="0,0,8,0"
                                                 Style="{StaticResource MapExplorerTextBox}"
                                                 TextChanged="MapExplorerXmlPathTextBox_TextChanged"/>
                                        <Button x:Name="mapExplorerBrowseXmlButton"
                                                Grid.Column="1"
                                                Width="72"
                                                Style="{StaticResource MapExplorerButton}"
                                                Click="MapExplorerBrowseXmlButton_Click"
                                                Content="Browse"/>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,8,0,0"
                                            Padding="8"
                                            BorderBrush="#FFD0D0D0"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8">
                                        <TextBlock Text="{Binding Text, ElementName=mapExplorerXmlPathTextBox}"
                                                   Style="{StaticResource MapExplorerStatusText}"
                                                   ToolTip="{Binding Text, ElementName=mapExplorerXmlPathTextBox}"/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <Border x:Name="mapExplorerSelectionBorder"
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                Padding="8"
                                BorderBrush="#FFD0D0D0"
                                BorderThickness="1"
                                Background="#FFF8F8F8">
                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="mapExplorerSelectionTextBlock"
                                       Grid.Row="0"
                                       Grid.ColumnSpan="4"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource MapExplorerStatusText}"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <Button x:Name="mapExplorerResolveMissingButton"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="112"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource MapExplorerButton}"
                                    Click="MapExplorerResolveMissingButton_Click"
                                    Content="Resolve Missing"/>
                            <Button x:Name="mapExplorerReloadButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Width="72"
                                    Style="{StaticResource MapExplorerButton}"
                                    Click="MapExplorerReloadButton_Click"
                                    Content="Reload"/>
                            <Button x:Name="mapExplorerLoadButton"
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Width="72"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource MapExplorerButton}"
                                    Click="MapExplorerLoadButton_Click"
                                    Content="Load"
                                    IsEnabled="False"/>
                            </Grid>
                        </Border>
                        </Grid>
                </TabItem>

                <TabItem x:Name="toolboxTabItem" Header="Toolbox">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Visible"
                                  x:Name="editorPanel">
                        <StackPanel Orientation="Vertical">

                            <Expander Header="Tile"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="tilePanelHost" Visibility="Collapsed">
                                    <editorItems:TilePanel x:Name="tilePanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander Header="Object"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="objPanelHost" Visibility="Collapsed">
                                    <editorItems:ObjPanel x:Name="objPanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander Header="Life"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="lifePanelHost" Visibility="Collapsed">
                                    <editorItems:LifePanel x:Name="lifePanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander Header="Portal"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="portalPanelHost" Visibility="Collapsed">
                                    <editorItems:PortalPanel x:Name="portalPanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander Header="Background"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="bgPanelHost" Visibility="Collapsed">
                                    <editorItems:BackgroundPanel x:Name="bgPanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander x:Name="expander_bgBlackBorderPanel"
                                      Header="Background Border"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="bgBlackBorderPanelHost" Visibility="Collapsed">
                                    <editorItems:BlackBorderPanel x:Name="bgBlackBorderPanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander Header="Common"
                                      Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
                                <WindowsFormsHost x:Name="commonPanelHost" Visibility="Collapsed">
                                    <editorItems:CommonPanel x:Name="commonPanel"/>
                                </WindowsFormsHost>
                            </Expander>

                            <Expander x:Name="expanderAIMapEditor"
                                      Header="AI Map Editor"
                                      Expanded="ExpanderAIMapEditor_Expanded"
                                      ToolTip="Open AI Map Editor for the current map"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="objectViewerTabItem" Header="Object Viewer">
                    <Grid>
                        <WindowsFormsHost x:Name="objectViewerPanelHostDocked">
                            <editorItems:ObjectViewerPanel x:Name="objectViewerPanelDocked"/>
                        </WindowsFormsHost>
                    </Grid>
                </TabItem>

                <TabItem x:Name="mapLoadErrorsTabItem" Header="Map Load Errors">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="mapLoadErrorsSummaryTextBlock"
                                   Grid.Row="0"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="mapLoadErrorsTextBox"
                                 Grid.Row="1"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="Consolas"/>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="mapLoadErrorsLogPathTextBlock"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button x:Name="mapLoadErrorsClearButton"
                                    Grid.Column="1"
                                    Width="88"
                                    Click="MapLoadErrorsClearButton_Click"
                                    Content="Clear"/>
                            <Button x:Name="mapLoadErrorsCopyButton"
                                    Grid.Column="2"
                                    Width="88"
                                    Margin="8,0,0,0"
                                    Click="MapLoadErrorsCopyButton_Click"
                                    Content="Copy All"/>
                            <Button x:Name="mapLoadErrorsOpenLogButton"
                                    Grid.Column="3"
                                    Width="88"
                                    Margin="8,0,0,0"
                                    Click="MapLoadErrorsOpenLogButton_Click"
                                    Content="Open Log"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <StatusBar x:Name="statusBar" Grid.Row="2" Grid.ColumnSpan="3">
            <StatusBarItem HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Game Cursor: X = " />
                        <TextBlock x:Name="textblock_CursorX" Text="0" />
                        <TextBlock Text=", Y = " />
                        <TextBlock x:Name="textblock_CursorY" Text="0" />

                        <TextBlock Text="|" Margin="20,0,20,0"/>
                        <TextBlock Text="Monitor cursor: X = " />
                        <TextBlock x:Name="textblock_RCursorX" Text="0" />
                        <TextBlock Text=", Y = " />
                        <TextBlock x:Name="textblock_RCursorY" Text="0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0">
                        <TextBlock Text="|" Margin="20,0,20,0"/>
                        <TextBlock Text="Selected item: " />
                        <TextBlock x:Name="textblock_selectedItem" Text="" />

                        <TextBlock Text="|" Margin="20,0,10,0"/>
                        <TextBlock Text="Zoom: " VerticalAlignment="Center"/>
                        <Button x:Name="btnZoomOut" Content="-" Width="20" Height="18"
                                Click="BtnZoomOut_Click" ToolTip="Zoom Out" Padding="0,-2,0,0"/>
                        <TextBlock x:Name="txtZoomLevel" Text="100%" Width="40" TextAlignment="Center"
                                   VerticalAlignment="Center" Margin="2,0"/>
                        <Button x:Name="btnZoomIn" Content="+" Width="20" Height="18"
                                Click="BtnZoomIn_Click" ToolTip="Zoom In" Padding="0,-2,0,0"/>
                        <Button x:Name="btnZoomReset" Content="1:1" Width="28" Height="18"
                                Click="BtnZoomReset_Click" ToolTip="Reset Zoom" Margin="4,0,0,0" Padding="0,-2,0,0"/>
                    </StackPanel>
                </Grid>
               
            </StatusBarItem>
        </StatusBar>
    </Grid>

</Window>
