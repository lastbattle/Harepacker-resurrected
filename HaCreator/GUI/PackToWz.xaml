<Window x:Class="HaCreator.GUI.PackToWz"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        xmlns:controls="clr-namespace:HaCreator.GUI.InfoEditorControls"
        Title="{dialogLoc:DialogText Dialog_Pack_IMG_files_to_WZ_11907C}" Width="720" Height="680"
        MinWidth="620" MinHeight="560" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}"
        Closing="PackToWz_FormClosing">
    <Window.Resources>
        <ResourceDictionary><ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
        </ResourceDictionary.MergedDictionaries></ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="{dialogLoc:DialogText Dialog_Choose_the_categories_and_target_format_for_the_generat_4E9F07}"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock x:Name="label_versionInfo" FontWeight="SemiBold" Text="{dialogLoc:DialogText Dialog_Unknown_B764CD}"/>
                <TextBlock Text="  •  "/>
                <TextBlock x:Name="label_format" Text="{dialogLoc:DialogText Dialog_Source_Unknown_14D3DB}"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Categories_to_pack_28422D}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="checkedListBox_categories" BorderThickness="0"/>
                </Border>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="{dialogLoc:DialogText Dialog_Select_all_1FC9A3}" Padding="12,5" Click="button_selectAll_Click"/>
                    <Button Content="{dialogLoc:DialogText Dialog_Select_none_41AFE0}" Padding="12,5" Margin="8,0,0,0" Click="button_selectNone_Click"/>
                </StackPanel>
            </Grid>
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"><StackPanel>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Output_format_93C53D}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <controls:CheckBox x:Name="checkBox_betaFormat" Content="{dialogLoc:DialogText Dialog_Pack_as_Beta_Data_wz_D2F012}" Checked="checkBox_betaFormat_CheckedChanged" Unchecked="checkBox_betaFormat_CheckedChanged"/>
                <controls:CheckBox x:Name="checkBox_64bit" Content="{dialogLoc:DialogText Dialog_Save_as_64_bit_WZ_format_4BC4B4}" Checked="checkBox_64bit_CheckedChanged" Unchecked="checkBox_64bit_CheckedChanged"/>
                <controls:CheckBox x:Name="checkBox_separateCanvas" Content="{dialogLoc:DialogText Dialog_Save_images_in_a_separate_Canvas_folder_0133B6}" Margin="18,2,0,8"/>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Patch_version_0_auto_45DAB0}" Margin="0,8,0,4"/>
                <controls:NumericUpDown x:Name="numericUpDown_patchVersion" Minimum="0" Maximum="32767" Text="0"/>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Encryption_82F4E7}" Margin="0,12,0,4"/>
                <ComboBox x:Name="comboBox_encryption"/>
                <controls:CheckBox x:Name="checkBox_saveChangedImages" Margin="0,14,0,0" Content="{dialogLoc:DialogText Dialog_Save_changed_images_to_source_3FCA18}"/>
            </StackPanel></ScrollViewer>
        </Grid>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="{dialogLoc:DialogText Dialog_Output_folder_998915}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBox x:Name="textBox_outputPath" Grid.Column="1"/>
            <Button x:Name="button_browse" Grid.Column="2" Content="{dialogLoc:DialogText Dialog_Browse_93C6B6}" Padding="14,5" Margin="8,0,0,0" Click="button_browse_Click"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <ProgressBar x:Name="progressBar" Height="8" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="label_status" Grid.Row="1" Text="{dialogLoc:DialogText Dialog_Ready_5FA7AA}" Margin="0,6,0,12" TextWrapping="Wrap"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="button_cancel" Content="{dialogLoc:DialogText Dialog_Close_7D9EB7}" Padding="20,7" Click="button_cancel_Click"/>
                <Button x:Name="button_pack" Content="{dialogLoc:DialogText Dialog_Pack_80DC21}" Padding="24,7" Margin="8,0,0,0" IsDefault="True" Click="button_pack_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
