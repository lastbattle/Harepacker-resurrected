<Window x:Class="HaCreator.GUI.Input.NameValueInputWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_Input_36ECB4}" Width="460" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="labelName" Text="{dialogLoc:DialogText Dialog_Name_2683CA}" VerticalAlignment="Center"/>
            <TextBox x:Name="nameInput" Grid.Column="1"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="labelValue" Text="{dialogLoc:DialogText Dialog_Value_224A33}" VerticalAlignment="Center"/>
            <TextBox x:Name="valueInput" Grid.Column="1" Text="0" InputScope="Number"/>
        </Grid>
        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="96" IsCancel="True" Click="Cancel_Click" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
            <Button MinWidth="96" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click" Content="{dialogLoc:DialogText Dialog_OK_565339}"/>
        </StackPanel>
    </Grid>
</Window>
