<Window x:Class="HaCreator.GUI.Input.IntInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Width="390" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid x:Name="nameRow">
            <Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="labelName" Text="{dialogLoc:DialogText Dialog_Name_2683CA}" VerticalAlignment="Center"/>
            <TextBox x:Name="nameBox" Grid.Column="1"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="labelValue" Text="{dialogLoc:DialogText Dialog_Value_224A33}" VerticalAlignment="Center"/>
            <TextBox x:Name="valueBox" Grid.Column="1" Text="0" InputScope="Number"/>
        </Grid>
        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="cancelButton" MinWidth="88" IsCancel="True" Click="CancelButton_Click" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
            <Button x:Name="okButton" MinWidth="88" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="OkButton_Click" Content="{dialogLoc:DialogText Dialog_OK_565339}"/>
        </StackPanel>
    </Grid>
</Window>
