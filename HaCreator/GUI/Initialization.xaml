<Window x:Class="HaCreator.GUI.Initialization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization"
        Title="{loc:Loc Init_WindowTitle}" Width="760" Height="570"
        MinWidth="680" MinHeight="500" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource HareCanvasBrush}"
        FontFamily="Segoe UI" Loaded="Initialization_Load" PreviewKeyDown="Initialization_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HareToolbarStyle}" Padding="22,16">
            <StackPanel>
                <TextBlock Margin="0,4,0,0" Text="{loc:Loc Init_Subheading}"
                           Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="tabControl_dataSource" Grid.Row="1" Margin="18,14"
                    SelectionChanged="tabControl_dataSource_SelectedIndexChanged">
            <TabItem x:Name="tabPage_wzFiles" Header="{loc:Loc Init_WzFilesTab}">
                <Border Margin="8" Padding="18" Style="{StaticResource HareCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="{loc:Loc Init_MapleStoryFolder}"/>
                        <ComboBox x:Name="pathBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,10" IsEditable="True"/>
                        <Button x:Name="button_browse" Grid.Row="0" Grid.Column="2" Margin="0,0,0,10"
                                MinWidth="88" Click="button_browseWz_Click" Content="{loc:Loc Common_BrowseEllipsis}"/>

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="{loc:Loc Init_WzEncryption}"/>
                        <ComboBox x:Name="versionBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <ComboBoxItem Content="GMS"/><ComboBoxItem Content="EMS, MSEA, KMS"/>
                            <ComboBoxItem Content="BMS, JMS"/><ComboBoxItem Content="Auto-detect"/>
                        </ComboBox>

                        <TextBlock x:Name="label1" Grid.Row="2" VerticalAlignment="Center" Text="{loc:Loc Init_ClientLocalisation}"/>
                        <ComboBox x:Name="comboBox_localisation" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                  DisplayMemberPath="Text" SelectedValuePath="Value"/>
                        <TextBlock x:Name="label4" Grid.Row="3" Grid.ColumnSpan="3" Margin="0,14,0,0"
                                   TextWrapping="Wrap" Style="{StaticResource HareMutedTextStyle}"
                                   Text="{loc:Loc Init_LocalisationHint}"/>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem x:Name="tabPage_imgVersions" Header="{loc:Loc Init_ImgVersionsTab}">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="5*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="4*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid>
                        <ListBox x:Name="listBox_imgVersions" FontSize="14"
                                 SelectionChanged="listBox_imgVersions_SelectedIndexChanged"
                                 MouseDoubleClick="listBox_imgVersions_DoubleClick"/>
                        <TextBlock x:Name="label_noVersions" Padding="24" TextAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" Style="{StaticResource HareMutedTextStyle}" Visibility="Collapsed"
                                   Text="{loc:Loc Init_NoVersions}"/>
                    </Grid>
                    <Border x:Name="panel_versionDetails" Grid.Column="2" Padding="16" Style="{StaticResource HareCardStyle}" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="label_versionName" Style="{StaticResource HareSectionTitleStyle}" Text="{loc:Loc Init_VersionName}"/>
                            <TextBlock x:Name="label_extractedDate" Margin="0,4,0,12" Style="{StaticResource HareMutedTextStyle}"/>
                            <TextBlock x:Name="label_encryptionInfo" Margin="0,3"/>
                            <TextBlock x:Name="label_format" Margin="0,3" TextWrapping="Wrap"/>
                            <TextBlock x:Name="label_imageCount" Margin="0,3"/>
                            <TextBlock x:Name="label_categoryCount" Margin="0,3"/>
                            <TextBlock x:Name="label_features" Margin="0,3" TextWrapping="Wrap"/>
                            <TextBlock x:Name="label_validationStatus" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <WrapPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
                        <Button x:Name="button_extractNew" MinWidth="104" ToolTip="{loc:Loc Init_ExtractTooltip}" Click="button_extractNew_Click" Content="{loc:Loc Init_ExtractNewEllipsis}"/>
                        <Button x:Name="button_browseVersion" MinWidth="88" Margin="8,0,0,0" ToolTip="{loc:Loc Init_AddVersionTooltip}" Click="button_browseVersion_Click" Content="{loc:Loc Common_BrowseEllipsis}"/>
                        <Button x:Name="button_refreshVersions" MinWidth="88" Margin="8,0,0,0" Click="button_refreshVersions_Click" Content="{loc:Loc Common_Refresh}"/>
                        <Button x:Name="button_renameVersion" MinWidth="88" Margin="20,0,0,0" IsEnabled="False" Click="button_renameVersion_Click" Content="{loc:Loc Common_Rename}"/>
                        <Button x:Name="button_deleteVersion" MinWidth="88" Margin="8,0,0,0" IsEnabled="False" Style="{StaticResource HareDangerButtonStyle}" Click="button_deleteVersion_Click" Content="{loc:Loc Common_Delete}"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="textBox2" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Style="{StaticResource HareMutedTextStyle}" Text="{loc:Loc Common_Ready}"/>
                <Button x:Name="button_settings" Grid.Column="1" MinWidth="96" Click="button_settings_Click" Content="{loc:Loc Common_Settings}"/>
                <Button x:Name="button_initialise" Grid.Column="2" Margin="10,0,0,0" MinWidth="130" IsDefault="True"
                        Style="{StaticResource HarePrimaryButtonStyle}" Click="button_initialise_Click" Content="{loc:Loc Common_Initialize}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
