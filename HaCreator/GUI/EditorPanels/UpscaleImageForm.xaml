<Window x:Class="HaCreator.GUI.EditorPanels.UpscaleImageForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Image Upscale"
        Width="960" Height="680" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI"
        KeyDown="Window_KeyDown" Closing="Window_Closing" Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <Style TargetType="Button" BasedOn="{StaticResource HareButtonStyle}">
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PreviewCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DCE3EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Compare the source with the AI-enhanced result before applying it."
                       Margin="0,5,0,0" Foreground="#64748B"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PreviewCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Original" FontSize="14" FontWeight="SemiBold" Foreground="#334155" Margin="2,0,0,10"/>
                    <Border Grid.Row="1" Background="#EEF2F7" CornerRadius="5" ClipToBounds="True">
                        <Image x:Name="BeforeImage" Stretch="Uniform"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PreviewCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="2,0,0,10">
                        <TextBlock Text="Enhanced" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                        <TextBlock x:Name="ProcessingStatus" Text="Processing…" Foreground="#64748B"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>
                    <Border Grid.Row="1" Background="#EEF2F7" CornerRadius="5" ClipToBounds="True">
                        <Image x:Name="AfterImage" Stretch="Uniform"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Text="The original asset is unchanged until you choose Use enhanced image."
                       VerticalAlignment="Center" Foreground="#64748B"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Click="Cancel_Click"/>
                <Button x:Name="AcceptButton" Content="Use enhanced image" IsDefault="True"
                        Style="{StaticResource PrimaryButton}" IsEnabled="False" Click="Accept_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
