<UserControl x:Class="HaCreator.GUI.EditorPanels.LifePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HaCreator.GUI.EditorPanels"
             MinWidth="220" MinHeight="320">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource HareCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="190"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HareToolbarStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource HareSectionTitleStyle}" Text="Life type"/>
                <StackPanel Margin="0,7,0,0" Orientation="Horizontal">
                    <RadioButton x:Name="mobRButton" Content="Mobs" IsChecked="True"
                                 GroupName="LifeMode" Checked="LifeModeChanged"/>
                    <RadioButton x:Name="npcRButton" Margin="16,2,0,2" Content="NPCs"
                                 GroupName="LifeMode" Checked="LifeModeChanged"/>
                    <RadioButton x:Name="reactorRButton" Margin="16,2,0,2" Content="Reactors"
                                 GroupName="LifeMode" Checked="LifeModeChanged"/>
                </StackPanel>
                <CheckBox x:Name="hideEntriesWithoutImagesCheckBox"
                          Margin="0,9,0,0"
                          Content="Hide entries without images"
                          Checked="ImageFilterChanged"
                          Unchecked="ImageFilterChanged"/>
            </StackPanel>
        </Border>

        <local:AssetGallery x:Name="lifeGallery" Grid.Row="1"
                            SelectionChanged="LifeGallery_SelectionChanged"/>

        <Border Grid.Row="2" Margin="8" Style="{StaticResource HareCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource HareSectionTitleStyle}" Text="Preview"/>
                <ScrollViewer Grid.Row="1" Margin="0,8,0,0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="lifePreview" Stretch="None"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
