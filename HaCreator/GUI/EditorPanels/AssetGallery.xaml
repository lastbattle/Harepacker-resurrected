<UserControl x:Class="HaCreator.GUI.EditorPanels.AssetGallery"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HaCreator.GUI.EditorPanels"
             xmlns:controls="clr-namespace:HaCreator.CustomControls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <Style x:Key="AssetTileStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="132"/>
            <Setter Property="MinHeight" Value="104"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <EventSetter Event="Loaded" Handler="AssetTile_Loaded"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TileBorder" Padding="8"
                                Background="{StaticResource HareSurfaceBrush}"
                                BorderBrush="{StaticResource HareBorderBrush}"
                                BorderThickness="1" CornerRadius="7">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="#94A3B8"/>
                                <Setter TargetName="TileBorder" Property="Background" Value="{StaticResource HareSurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{StaticResource HareAccentBrush}"/>
                                <Setter TargetName="TileBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="TileBorder" Property="Background" Value="{StaticResource HareAccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource HareSurfaceAltBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox" Margin="8,8,8,4"
                 ToolTip="Filter assets by name"
                 TextChanged="SearchBox_TextChanged"/>

        <ListBox x:Name="AssetList" Grid.Row="1" Margin="4"
                 Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource AssetTileStyle}"
                 SelectionChanged="AssetList_SelectionChanged"
                 PreviewMouseLeftButtonDown="AssetList_PreviewMouseLeftButtonDown"
                 PreviewMouseRightButtonDown="AssetList_PreviewMouseRightButtonDown"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.CacheLength="1,2"
                 VirtualizingPanel.CacheLengthUnit="Page">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:VirtualizingWrapPanel IsItemsHost="True"
                                                     ItemWidth="140"
                                                     ItemHeight="112"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:AssetGalleryItem}">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Height" Value="88"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                        <Setter Property="Height" Value="Auto"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Image Source="{Binding Image}" Stretch="Uniform"
                               SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="LowQuality">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Grid.Row="1" Margin="0,7,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource HareTextBrush}"
                                   Text="{Binding Name}" TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Name}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
