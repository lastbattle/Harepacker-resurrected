<Window x:Class="HaCreator.GUI.EditorPanels.AISettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI endpoint settings" Width="650" Height="680" MinWidth="560" MinHeight="600"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI"
        Loaded="AISettingsDialog_Loaded" Closed="AISettingsDialog_Closed">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource HareToolbarStyle}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="Configure an OpenAI-compatible endpoint and verify it before saving."
                           Margin="0,4,0,0" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Border Style="{StaticResource HareCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Endpoint" Style="{StaticResource HareSectionTitleStyle}"/>
                        <TextBlock Text="Base URL" Margin="0,12,0,4"/>
                        <TextBox x:Name="txtBaseUrl" TextChanged="OnSettingsChanged" LostKeyboardFocus="TxtBaseUrl_Leave"/>
                        <TextBlock Text="API key" Margin="0,10,0,4"/>
                        <PasswordBox x:Name="txtApiKey" PasswordChanged="OnSettingsChanged" LostKeyboardFocus="TxtApiKey_Leave"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0" Style="{StaticResource HareCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Model catalog" Style="{StaticResource HareSectionTitleStyle}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="cboModel" IsEditable="True" IsTextSearchEnabled="False"
                                      SelectionChanged="CboModel_SelectedIndexChanged"/>
                            <Button x:Name="btnRefreshModels" Grid.Column="1" Margin="8,0,0,0" MinWidth="92"
                                    Click="BtnRefreshModels_Click" Content="Refresh"/>
                        </Grid>
                        <TextBlock Text="Built-in and endpoint models share one list. Type a custom model ID if needed."
                                   Margin="0,6,0,0" Style="{StaticResource HareMutedTextStyle}"/>
                        <TextBlock x:Name="lblModelsStatus" Margin="0,6,0,0" Style="{StaticResource HareMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0" Style="{StaticResource HareCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="API dialect"/>
                            <ComboBox x:Name="cboApiDialect" Margin="0,4,0,0" SelectionChanged="OnSettingsChanged">
                                <ComboBoxItem Content="Chat Completions"/><ComboBoxItem Content="Responses"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Reasoning effort"/>
                            <ComboBox x:Name="cboReasoningEffort" Margin="0,4,0,0" SelectionChanged="OnSettingsChanged"/>
                        </StackPanel>
                        <TextBlock x:Name="lblReasoningStatus" Grid.ColumnSpan="3" Margin="0,64,0,0"
                                   Style="{StaticResource HareMutedTextStyle}"/>
                    </Grid>
                </Border>
                <Border Margin="0,12,0,0" Style="{StaticResource HareCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Map editing behavior" Style="{StaticResource HareSectionTitleStyle}"/>
                        <CheckBox x:Name="chkStrictSchemas" Margin="0,10,0,0" Checked="OnSettingsChanged" Unchecked="OnSettingsChanged"
                                  Content="Use strict tool schemas"/>
                        <CheckBox x:Name="chkAutoApply" Margin="0,7,0,0" Checked="OnSettingsChanged" Unchecked="OnSettingsChanged"
                                  Content="Apply generated map edits automatically"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="lblStatus" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>
                <Button x:Name="btnTest" Grid.Column="1" MinWidth="120" Click="BtnTest_Click" Content="Test connection"/>
                <Button Grid.Column="2" Margin="8,0,0,0" MinWidth="88" IsCancel="True" Content="Cancel"/>
                <Button x:Name="btnSave" Grid.Column="3" Margin="8,0,0,0" MinWidth="88" IsDefault="True" IsEnabled="False"
                        Style="{StaticResource HarePrimaryButtonStyle}" Click="BtnSave_Click" Content="Save"/>
            </Grid>
        </Border>
    </Grid>
</Window>
