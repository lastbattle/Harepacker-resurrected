<Window x:Class="HaCreator.GUI.MigrationWizard" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization" Title="{dialogLoc:DialogText Dialog_Migrate_WZ_files_70876B}" Width="720" Height="590" MinWidth="600" MinHeight="480" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Margin="20">
            <StackPanel x:Name="panel_welcome">
                <TextBlock Margin="0,10,0,0" Text="{dialogLoc:DialogText Dialog_This_wizard_extracts_a_MapleStory_WZ_installation_into_A3FE9D}" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>

            <Grid x:Name="panel_selectSource" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Select_source_140B76}" Style="{StaticResource HarePageTitleStyle}"/>
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource HareCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{dialogLoc:DialogText Dialog_Detected_installations_EAE79D}" Style="{StaticResource HareSectionTitleStyle}"/>
                            <ListBox x:Name="listBox_detected" Margin="0,8,0,0" Height="250" SelectionChanged="listBox_detected_SelectedIndexChanged"/>
                            <Button Margin="0,10,0,0" Click="button_scanFolder_Click" Content="{dialogLoc:DialogText Dialog_Scan_folder_48FCB3}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource HareCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{dialogLoc:DialogText Dialog_Manual_folder_959DA1}" Style="{StaticResource HareSectionTitleStyle}"/>
                            <TextBox x:Name="textBox_wzPath" Margin="0,8,0,0" IsReadOnly="True"/>
                            <Button Margin="0,10,0,0" Click="button_browse_Click" Content="{dialogLoc:DialogText Dialog_Browse_3227AA}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            <StackPanel x:Name="panel_configure" Visibility="Collapsed">
                <TextBlock Text="{dialogLoc:DialogText Dialog_Configure_version_BA4170}" Style="{StaticResource HarePageTitleStyle}"/>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Version_name_C5BE1C}" Margin="0,16,0,4"/>
                <TextBox x:Name="textBox_versionName" TextChanged="textBox_versionName_TextChanged"/>
                <TextBlock x:Name="label_versionError" Margin="0,4,0,0" Foreground="{DynamicResource HareDangerBrush}"/>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Display_name_2B7F6A}" Margin="0,12,0,4"/>
                <TextBox x:Name="textBox_displayName" TextChanged="textBox_displayName_TextChanged"/>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Encryption_82F4E7}" Margin="0,12,0,4"/>
                <ComboBox x:Name="comboBox_encryption" SelectionChanged="comboBox_encryption_SelectedIndexChanged"/>
            </StackPanel>
            <Grid x:Name="panel_progress" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Extracting_assets_17CB7D}" Style="{StaticResource HarePageTitleStyle}"/>
                <TextBlock x:Name="label_progress" Grid.Row="1" Margin="0,10"/>
                <ListBox x:Name="listBox_log" Grid.Row="2" FontFamily="Consolas"/>
                <ProgressBar x:Name="progressBar_extraction" Grid.Row="2" Height="5" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
        <Border Grid.Row="1" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="label_stepInfo" VerticalAlignment="Center"/>
                <Button x:Name="button_back" Grid.Column="1" MinWidth="88" Click="button_back_Click" Content="{dialogLoc:DialogText Dialog_Back_76900F}"/>
                <Button x:Name="button_cancel" Grid.Column="2" Margin="8,0,0,0" MinWidth="88" Click="button_cancel_Click" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
                <Button x:Name="button_next" Grid.Column="3" Margin="8,0,0,0" MinWidth="110" Style="{StaticResource HarePrimaryButtonStyle}" Click="button_next_Click" Content="{dialogLoc:DialogText Dialog_Next_1FF57A}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
