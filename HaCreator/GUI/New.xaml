<Window x:Class="HaCreator.GUI.New" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_Create_map_AD41DE}" Width="500" Height="350" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" Margin="0,14,0,0">
            <TabItem Header="{dialogLoc:DialogText Dialog_Blank_map_8DF131}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{dialogLoc:DialogText Dialog_Width_301994}"/>
                            <TextBox x:Name="newWidth" Margin="0,4,0,0" InputScope="Number"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{dialogLoc:DialogText Dialog_Height_BFE2EC}"/>
                            <TextBox x:Name="newHeight" Margin="0,4,0,0" InputScope="Number"/>
                        </StackPanel>
                    </Grid>
                    <Button Grid.Row="1" Margin="0,18,0,0" HorizontalAlignment="Right" Style="{StaticResource HarePrimaryButtonStyle}" IsDefault="True" Click="CreateNew_Click" Content="{dialogLoc:DialogText Dialog_Create_blank_map_A7F938}"/>
                </Grid>
            </TabItem>
            <TabItem Header="{dialogLoc:DialogText Dialog_Clone_map_36503E}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="cloneMapId" Text="-1" TextChanged="CloneMapId_TextChanged" InputScope="Number"/>
                        <Button Grid.Column="1" Margin="8,0,0,0" Click="SelectCloneMap_Click" Content="{dialogLoc:DialogText Dialog_Browse_maps_75E8C8}"/>
                    </Grid>
                    <Button x:Name="createCloneButton" Grid.Row="1" Margin="0,18,0,0" HorizontalAlignment="Right" IsEnabled="False" Style="{StaticResource HarePrimaryButtonStyle}" Click="CreateClone_Click" Content="{dialogLoc:DialogText Dialog_Create_from_map_CFB30F}"/>
                </Grid>
            </TabItem>
        </TabControl>
        <Button Grid.Row="2" HorizontalAlignment="Right" MinWidth="88" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
    </Grid>
</Window>
