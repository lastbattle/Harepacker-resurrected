<Window x:Class="HaCreator.GUI.ManageUserObjects"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_Manage_custom_objects_2FDA41}" Width="620" Height="440"
        MinWidth="500" MinHeight="340" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource HareCanvasBrush}"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,14">
            <TextBlock Margin="0,4,0,0" Style="{StaticResource HareMutedTextStyle}"
                       Text="{dialogLoc:DialogText Dialog_Review_reusable_objects_created_in_this_workspace_and_f_D306AC}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource HareCardStyle}" Padding="0">
                <ListBox x:Name="objsList" BorderThickness="0" SelectionChanged="ObjectsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="1" Padding="6,2" Background="#DCFCE7" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNew}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" Foreground="{StaticResource HareSuccessBrush}" Text="{dialogLoc:DialogText Dialog_NEW_A253FF}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Grid.Column="2">
                <Button x:Name="searchBtn" Margin="0,0,0,8" IsEnabled="False"
                        Style="{StaticResource HarePrimaryButtonStyle}"
                        Click="SearchButton_Click" Content="{dialogLoc:DialogText Dialog_Find_usages_1A0A20}"/>
                <Button x:Name="removeBtn" IsEnabled="False"
                        Style="{StaticResource HareDangerButtonStyle}"
                        Click="RemoveButton_Click" Content="{dialogLoc:DialogText Dialog_Delete_object_0B1BBB}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Margin="0,14,0,0" Padding="10,8"
                Background="{StaticResource HareSurfaceAltBrush}" CornerRadius="6">
            <TextBlock Style="{StaticResource HareMutedTextStyle}"
                       Text="{dialogLoc:DialogText Dialog_Deleting_an_object_removes_it_from_the_custom_object_li_D93856}"/>
        </Border>
    </Grid>
</Window>
