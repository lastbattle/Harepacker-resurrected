<Window x:Class="HaCreator.GUI.MapLoadErrorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_Map_diagnostics_269074}"
        Height="560"
        Width="800"
        MinHeight="360"
        MinWidth="480"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Topmost="False"
        Background="{DynamicResource HareCanvasBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DCE3EC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="18,14" Background="{StaticResource HareSurfaceBrush}" BorderBrush="{StaticResource HareBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="28" Height="28" Background="#FFF7ED" CornerRadius="6">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#C2410C" FontSize="17" FontWeight="Bold" Text="!"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="summaryTextBlock" Margin="0,3,0,0" Foreground="#64748B" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16" Background="{StaticResource HareSurfaceBrush}" BorderBrush="{StaticResource HareBorderBrush}" BorderThickness="1" CornerRadius="7">
            <TextBox x:Name="errorsTextBox"
                     Margin="1"
                     Padding="12"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#334155"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="12"/>
        </Border>

        <Border Grid.Row="2" Padding="16,12" Background="{StaticResource HareSurfaceBrush}" BorderBrush="{StaticResource HareBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="logPathTextBlock" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                <Button x:Name="closeButton" Grid.Column="1" Style="{StaticResource DialogButtonStyle}"
                        Click="CloseButton_Click" Content="{dialogLoc:DialogText Dialog_Close_7D9EB7}"/>
                <Button x:Name="copyButton" Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource DialogButtonStyle}"
                        Click="CopyButton_Click" Content="{dialogLoc:DialogText Dialog_Copy_all_96E3F0}"/>
                <Button x:Name="openLogButton" Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource DialogButtonStyle}"
                        Click="OpenLogButton_Click" Content="{dialogLoc:DialogText Dialog_Open_log_7230E6}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
