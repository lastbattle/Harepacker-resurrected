<Window x:Class="HaCreator.GUI.MapLoadErrorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Load Errors"
        Height="520"
        Width="760"
        MinHeight="320"
        MinWidth="420"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Topmost="False">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="summaryTextBlock"
                   Grid.Row="0"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"/>

        <TextBox x:Name="errorsTextBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 FontFamily="Consolas"/>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="logPathTextBlock"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       TextTrimming="CharacterEllipsis"/>
            <Button x:Name="closeButton"
                    Grid.Column="1"
                    Width="88"
                    Click="CloseButton_Click"
                    Content="Close"/>
            <Button x:Name="copyButton"
                    Grid.Column="2"
                    Width="88"
                    Margin="8,0,0,0"
                    Click="CopyButton_Click"
                    Content="Copy All"/>
            <Button x:Name="openLogButton"
                    Grid.Column="3"
                    Width="88"
                    Margin="8,0,0,0"
                    Click="OpenLogButton_Click"
                    Content="Open Log"/>
        </Grid>
    </Grid>
</Window>
