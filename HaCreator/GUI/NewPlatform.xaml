<Window x:Class="HaCreator.GUI.NewPlatform"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_New_platform_20103C}" Width="380" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{dialogLoc:DialogText Dialog_Platform_number_DD431C}" Style="{StaticResource HareSectionTitleStyle}"/>
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="36"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="platformBox" Text="0" TextChanged="Platform_TextChanged" InputScope="Number"/>
            <Button x:Name="decrementButton" Grid.Column="1" Margin="6,0,0,0" Padding="0"
                    Click="Step_Click" Content="-"/>
            <Button x:Name="incrementButton" Grid.Column="2" Margin="4,0,0,0" Padding="0"
                    Click="Step_Click" Content="+"/>
        </Grid>
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="statusLabel" Foreground="{DynamicResource HareDangerBrush}"/>
            <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button MinWidth="88" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
                <Button x:Name="okButton" MinWidth="88" Margin="8,0,0,0" IsDefault="True"
                        Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click" Content="{dialogLoc:DialogText Dialog_OK_565339}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
