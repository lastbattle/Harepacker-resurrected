<Window x:Class="HaCreator.GUI.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_About_HaCreator_D7275A}" Width="520" Height="560"
        MinWidth="440" MinHeight="440" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}"
        FontFamily="Segoe UI" KeyDown="About_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource HareCardStyle}" Padding="20">
            <StackPanel>
                <TextBlock Text="{dialogLoc:DialogText Dialog_HaCreator_resurrected_8AD585}" Style="{StaticResource HarePageTitleStyle}"/>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Map_editor_for_MapleStory_WZ_data_F80834}" Margin="0,5,0,0" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="0,14" Style="{StaticResource HareCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{dialogLoc:DialogText Dialog_Credits_and_attributions_8F890E}" Style="{StaticResource HareSectionTitleStyle}"/>
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{DynamicResource HareTextBrush}">
                        <Run Text="{dialogLoc:DialogText Dialog_Tile_snapping_offsets_special_list_view_control_and_mob_81965C}"/>
                        <Run Text="{dialogLoc:DialogText Dialog_Field_limits_field_types_and_portal_types_Koolk_Fiel_Bl_54AB6B}"/>
                        <Run Text="{dialogLoc:DialogText Dialog_Graphics_and_GUI_Anthonywolfe_Diamondo25_Bugale_98E17C}"/>
                        <Run Text="{dialogLoc:DialogText Dialog_Physics_and_character_simulation_research_Lexi_9E98C8}"/>
                        <Run Text="{dialogLoc:DialogText Dialog_Background_formulae_Koolk_God_F7E779}"/>
                        <Run Text="{dialogLoc:DialogText Dialog_MapleLib_Snow_0E19E4}"/>
                        <Run Text="{dialogLoc:DialogText Dialog_Repacker_Resurrection_LastBattle_HaCreator_Resurrection_7F3172}"/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button HorizontalAlignment="Left" Click="Repository_Click" Content="{dialogLoc:DialogText Dialog_Open_project_repository_50B264}"/>
            <Button Grid.Column="1" MinWidth="88" IsDefault="True" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Close_7D9EB7}"/>
        </Grid>
    </Grid>
</Window>
