<Window x:Class="HaCreator.GUI.TileSetBrowser" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization" xmlns:panels="clr-namespace:HaCreator.GUI.EditorPanels"
 Title="{dialogLoc:DialogText Dialog_Choose_tile_set_7EB655}" Width="760" Height="620" MinWidth="520" MinHeight="400" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource HareToolbarStyle}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Search_and_select_a_tile_set_for_the_active_layer_E5FB28}" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>
        <panels:AssetGallery x:Name="gallery" Grid.Row="1" Margin="20"/>
        <Border Grid.Row="2" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button MinWidth="88" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
                <Button Margin="8,0,0,0" MinWidth="88" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="Select_Click" Content="{dialogLoc:DialogText Dialog_Select_2A7802}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
