<Window x:Class="HaCreator.GUI.DataSourceSettingsWindow" x:ClassModifier="internal" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
 Title="{dialogLoc:DialogText Dialog_Data_source_settings_6660A7}" Width="660" Height="690" MinHeight="560" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource HareToolbarStyle}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Choose_how_HaCreator_loads_and_caches_MapleStory_assets_D8EF67}" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <Border Style="{StaticResource HareCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{dialogLoc:DialogText Dialog_Mode_5E23EC}" Style="{StaticResource HareSectionTitleStyle}"/>
                        <WrapPanel Margin="0,10,0,0">
                            <RadioButton x:Name="imgMode" GroupName="mode" Checked="Mode_Checked" Content="{dialogLoc:DialogText Dialog_IMG_filesystem_5D40A3}"/>
                            <RadioButton x:Name="wzMode" Margin="18,2,0,2" GroupName="mode" Checked="Mode_Checked" Content="{dialogLoc:DialogText Dialog_WZ_files_8F86F3}"/>
                            <RadioButton x:Name="hybridMode" Margin="18,2,0,2" GroupName="mode" Checked="Mode_Checked" Content="{dialogLoc:DialogText Dialog_Hybrid_6C67DC}"/>
                        </WrapPanel>
                        <TextBlock x:Name="modeDescription" Margin="0,10,0,0" Style="{StaticResource HareMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0" Style="{StaticResource HareCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{dialogLoc:DialogText Dialog_WZ_path_AA541C}" Style="{StaticResource HareSectionTitleStyle}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="wzPath"/>
                            <Button x:Name="browseWz" Grid.Column="1" Margin="8,0,0,0" Click="BrowseWz_Click" Content="{dialogLoc:DialogText Dialog_Browse_3227AA}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border x:Name="cacheCard" Margin="0,12,0,0" Style="{StaticResource HareCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{dialogLoc:DialogText Dialog_Memory_cache_MB_CF25E8}"/>
                            <TextBox x:Name="maxMemory" Margin="0,4,0,0" InputScope="Number"/>
                            <CheckBox x:Name="memoryMapped" Margin="0,10,0,0" Content="{dialogLoc:DialogText Dialog_Use_memory_mapped_files_EDB079}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{dialogLoc:DialogText Dialog_Cached_images_CCAEA9}"/>
                            <TextBox x:Name="maxImages" Margin="0,4,0,0" InputScope="Number"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Margin="0,12,0,0" Style="{StaticResource HareCardStyle}">
                    <StackPanel>
                        <CheckBox x:Name="allowFallback" Content="{dialogLoc:DialogText Dialog_Allow_WZ_fallback_in_hybrid_mode_C01FB6}"/>
                        <CheckBox x:Name="autoConvert" Margin="0,7,0,0" Content="{dialogLoc:DialogText Dialog_Convert_WZ_assets_automatically_DA87FF}"/>
                        <CheckBox x:Name="generateIndex" Margin="0,7,0,0" Content="{dialogLoc:DialogText Dialog_Generate_extraction_index_B7D7D5}"/>
                        <CheckBox x:Name="validateExtract" Margin="0,7,0,0" Content="{dialogLoc:DialogText Dialog_Validate_after_extraction_7FAB37}"/>
                        <TextBlock Text="{dialogLoc:DialogText Dialog_Parallel_extraction_threads_23467E}" Margin="0,10,0,4"/>
                        <TextBox x:Name="parallelThreads" Width="120" HorizontalAlignment="Left" InputScope="Number"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button HorizontalAlignment="Left" Click="Reset_Click" Content="{dialogLoc:DialogText Dialog_Reset_defaults_4542D4}"/>
                <Button Grid.Column="1" MinWidth="88" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
                <Button Grid.Column="2" Margin="8,0,0,0" MinWidth="88" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="Save_Click" Content="{dialogLoc:DialogText Dialog_Save_1509F5}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
