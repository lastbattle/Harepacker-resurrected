<Window x:Class="HaCreator.GUI.MapPhysicsEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
 Title="{dialogLoc:DialogText Dialog_Map_physics_C03020}" Width="560" Height="720" MinHeight="500" WindowStartupLocation="CenterOwner" Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource HareToolbarStyle}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="{dialogLoc:DialogText Dialog_Edit_values_stored_in_Map_Physics_img_3C88D3}" Style="{StaticResource HareMutedTextStyle}"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Margin="20" Style="{StaticResource HareCardStyle}">
                <StackPanel x:Name="fieldsPanel"/>
            </Border>
        </ScrollViewer>
        <Border Grid.Row="2" Style="{StaticResource HareToolbarStyle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="errorText" Foreground="{DynamicResource HareDangerBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="Reset_Click" Content="{dialogLoc:DialogText Dialog_Reset_defaults_4542D4}"/>
                <Button Grid.Column="2" Margin="8,0,0,0" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Cancel_19766E}"/>
                <Button x:Name="saveButton" Grid.Column="3" Margin="8,0,0,0" IsDefault="True" Style="{StaticResource HarePrimaryButtonStyle}" Click="Save_Click" Content="{dialogLoc:DialogText Dialog_Save_1509F5}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
