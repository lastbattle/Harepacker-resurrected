<Window x:Class="HaCreator.GUI.InstanceEditor.MassZmEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" Title="{loc:Loc IE_zM}" Width="360" Height="220" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"><Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources><Grid Background="{StaticResource HareCanvasBrush}" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="{loc:Loc IE_Set_platform_zM_for_selected_items}" Style="{StaticResource HareSectionTitleStyle}"/><StackPanel Grid.Row="1" Margin="0,14"><TextBlock Text="{loc:Loc IE_zM}"/><TextBox x:Name="zmInput" Margin="0,5,0,0"/></StackPanel><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="CancelButton_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" IsDefault="True" Click="OkButton_Click"/></StackPanel></Grid></Window>
