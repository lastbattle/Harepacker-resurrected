<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.MirrorFieldEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI" Title="{loc:Loc IE_Mirror_field}" Width="520" Height="470" ResizeMode="NoResize"><local:EditorBase.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></local:EditorBase.Resources><Grid Background="{StaticResource HareCanvasBrush}" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="pathLabel" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/><StackPanel Grid.Row="1" Margin="0,14"><CheckBox x:Name="checkBox_reflection" Content="{loc:Loc IE_Reflection}"/><CheckBox x:Name="checkBox_alphaTest" Content="{loc:Loc IE_Alpha_test}"/><TextBlock Margin="0,10,0,0" Text="{loc:Loc IE_Overlay_object}"/><ComboBox x:Name="comboBox_objectForOverlay" Margin="0,4,0,10"><ComboBoxItem Content="{loc:Loc IE_mirror}"/></ComboBox><UniformGrid Columns="2"><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_X_offset}"/><TextBox x:Name="xOffset" Margin="0,4,0,0"/></StackPanel><StackPanel><TextBlock Text="{loc:Loc IE_Y_offset}"/><TextBox x:Name="yOffset" Margin="0,4,0,0"/></StackPanel></UniformGrid><TextBlock x:Name="label_gradient" Margin="0,12,0,0"/><Slider x:Name="gradientSlider" Minimum="0" Maximum="255" ValueChanged="Gradient_Changed"/><TextBlock x:Name="label_alphaValue" Margin="0,8,0,0"/><Slider x:Name="alphaSlider" Minimum="0" Maximum="255" ValueChanged="Alpha_Changed"/></StackPanel><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/></StackPanel></Grid></local:EditorBase>
