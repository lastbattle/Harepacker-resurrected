<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.BackgroundInstanceEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI" Title="{loc:Loc IE_Background_instance}" Width="650" Height="720">
    <local:EditorBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </local:EditorBase.Resources>
    <Grid Background="{StaticResource HareCanvasBrush}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="pathLabel" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/>
        <ScrollViewer Grid.Row="1" Margin="0,12">
            <StackPanel>
                <UniformGrid Columns="3">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc IE_X}"/>
                        <TextBox x:Name="xInput"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc IE_Y}"/>
                        <TextBox x:Name="yInput"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc IE_Z}"/>
                        <TextBox x:Name="zInput"/>
                    </StackPanel>
                </UniformGrid>
                <UniformGrid Columns="2" Margin="0,12,0,0">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc IE_Type}"/>
                        <ComboBox x:Name="typeBox" SelectionChanged="Type_Changed"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc IE_Screen_mode}"/>
                        <ComboBox x:Name="screenModeBox"/>
                    </StackPanel>
                </UniformGrid>
                <TextBlock x:Name="typeDescription" Margin="0,6,0,10" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/>
                <WrapPanel>
                    <CheckBox x:Name="frontBox" Content="{loc:Loc IE_Front}"/>
                    <CheckBox x:Name="flipBox" Margin="16,2,0,2" Content="{loc:Loc IE_Flip}"/>
                </WrapPanel>
                <UniformGrid Columns="2" Margin="0,10,0,0">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc IE_Alpha}"/>
                        <TextBox x:Name="alphaBox"/>
                        <TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_RX}"/>
                        <TextBox x:Name="rxBox"/>
                        <TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_CX}"/>
                        <TextBox x:Name="cxBox"/>
                        <TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_Page}"/>
                        <TextBox x:Name="pageInput"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc IE_RY}"/>
                        <TextBox x:Name="ryBox"/>
                        <TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_CY}"/>
                        <TextBox x:Name="cyBox"/>
                    </StackPanel>
                </UniformGrid>
                <GroupBox x:Name="spineGroup" Margin="0,12,0,0" Header="{loc:Loc IE_Spine}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc IE_Animation}"/>
                        <ComboBox x:Name="spineAnimationBox"/>
                        <CheckBox x:Name="spineRandomStartBox" Margin="0,8,0,0" Content="{loc:Loc IE_Random_start}"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/>
            <Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</local:EditorBase>
