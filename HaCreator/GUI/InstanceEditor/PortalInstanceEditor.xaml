<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.PortalInstanceEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI" Title="{loc:Loc IE_Portal_instance}" Width="700" Height="790" MinHeight="600"><local:EditorBase.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></local:EditorBase.Resources><Grid Background="{StaticResource HareCanvasBrush}" Margin="16"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><ScrollViewer><StackPanel><UniformGrid Columns="2"><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_X}"/><TextBox x:Name="xInput"/></StackPanel><StackPanel><TextBlock Text="{loc:Loc IE_Y}"/><TextBox x:Name="yInput"/></StackPanel></UniformGrid><TextBlock Margin="0,10,0,0" Text="{loc:Loc IE_Portal_type}"/><ComboBox x:Name="ptComboBox" SelectionChanged="PortalType_Changed"/><StackPanel x:Name="pnSection"><TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_Portal_name}"/><TextBox x:Name="pnBox"/></StackPanel><StackPanel x:Name="targetSection"><CheckBox x:Name="thisMap" Margin="0,8,0,0" Content="{loc:Loc IE_Target_this_map}" Checked="ThisMap_Changed" Unchecked="ThisMap_Changed"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="tmBox"/><Button x:Name="browseMapButton" Grid.Column="1" Margin="6,0,0,0" Content="{loc:Loc IE_Browse_map}" Click="BrowseMap_Click"/></Grid><Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="tnBox"/><Button x:Name="browseTnButton" Grid.Column="1" Margin="6,0,0,0" Content="{loc:Loc IE_Browse_portal}" Click="BrowseTn_Click"/></Grid></StackPanel><StackPanel x:Name="scriptSection"><TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_Script}"/><TextBox x:Name="scriptBox"/></StackPanel><CheckBox x:Name="delayEnable" Margin="0,8,0,0" Content="{loc:Loc IE_Delay}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="delayBox" Margin="22,3,0,0"/><StackPanel x:Name="rangeSection"><CheckBox x:Name="rangeEnable" Margin="0,8,0,0" Content="{loc:Loc IE_Range}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><UniformGrid Columns="2" Margin="22,3,0,0"><TextBox x:Name="hRangeBox"/><TextBox x:Name="vRangeBox" Margin="6,0,0,0"/></UniformGrid></StackPanel><StackPanel x:Name="impactSection"><UniformGrid Columns="2" Margin="0,8,0,0"><StackPanel Margin="0,0,8,0"><CheckBox x:Name="hImpactEnable" Content="{loc:Loc IE_Horizontal_impact}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="hImpactBox" Margin="22,3,0,0"/></StackPanel><StackPanel><CheckBox x:Name="vImpactEnable" Content="{loc:Loc IE_Vertical_impact}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="vImpactBox" Margin="22,3,0,0"/></StackPanel></UniformGrid></StackPanel><WrapPanel x:Name="boolSection" Margin="0,8,0,0"><CheckBox x:Name="onlyOnce" Content="{loc:Loc IE_Only_once}"/><CheckBox x:Name="hideTooltip" Margin="16,2,0,2" Content="{loc:Loc IE_Hide_tooltip}"/></WrapPanel><TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_Reactor_name}"/><TextBox x:Name="reactorNameBox"/><TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_Session_key}"/><TextBox x:Name="sessionKeyBox"/><TextBlock Margin="0,8,0,0" Text="{loc:Loc IE_Session_value}"/><TextBox x:Name="sessionValueBox"/><Grid x:Name="imageSection" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><ListBox x:Name="portalImageList" Height="145" SelectionChanged="PortalImage_Changed"/><Border Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource HareCardStyle}"><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"><Image x:Name="portalImage" Stretch="None"/></ScrollViewer></Border></Grid></StackPanel></ScrollViewer><StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/></StackPanel></Grid></local:EditorBase>
