<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.TileInstanceEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI" Title="{loc:Loc IE_Tile}" Width="420" Height="290" ResizeMode="NoResize"><local:EditorBase.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></local:EditorBase.Resources><Grid Background="{StaticResource HareCanvasBrush}" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="pathLabel" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/><UniformGrid Grid.Row="1" Columns="3" Margin="0,16"><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_X}"/><TextBox x:Name="xInput" Margin="0,5,0,0"/></StackPanel><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_Y}"/><TextBox x:Name="yInput" Margin="0,5,0,0"/></StackPanel><StackPanel><TextBlock Text="{loc:Loc IE_Z}"/><TextBox x:Name="zInput" Margin="0,5,0,0"/></StackPanel></UniformGrid><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/></StackPanel></Grid></local:EditorBase>
