<Window x:Class="HaCreator.GUI.InstanceEditor.GeneralInstanceEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" Title="{loc:Loc IE_General}" Width="400" Height="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"><Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources><Grid Background="{StaticResource HareCanvasBrush}" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="pathLabel" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/><Grid Grid.Row="1" Margin="0,16"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{loc:Loc IE_X}"/><TextBox x:Name="xInput" Margin="0,5,8,0"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="{loc:Loc IE_Y}"/><TextBox x:Name="yInput" Margin="0,5,8,0"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="{loc:Loc IE_Z}"/><TextBox x:Name="zInput" Margin="0,5,0,0"/></StackPanel></Grid><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="CancelButton_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" IsDefault="True" Click="OkButton_Click"/></StackPanel></Grid></Window>
