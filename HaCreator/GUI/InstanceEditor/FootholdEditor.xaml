<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.FootholdEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI" Title="{loc:Loc IE_Foothold}" Width="430" Height="350" ResizeMode="NoResize">
    <local:EditorBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </local:EditorBase.Resources>
    <Grid Background="{StaticResource HareCanvasBrush}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <CheckBox x:Name="forceEnable" Content="{loc:Loc IE_Force}" IsThreeState="True" Checked="Force_Changed" Unchecked="Force_Changed" Indeterminate="Force_Changed"/>
            <TextBox x:Name="forceInt" Margin="22,4,0,12"/>
            <CheckBox x:Name="pieceEnable" Content="{loc:Loc IE_Piece}" IsThreeState="True" Checked="Piece_Changed" Unchecked="Piece_Changed" Indeterminate="Piece_Changed"/>
            <TextBox x:Name="pieceInt" Margin="22,4,0,12"/>
            <CheckBox x:Name="cantThroughBox" Content="{loc:Loc IE_Cannot_pass_through}" IsThreeState="True"/>
            <CheckBox x:Name="forbidFallDownBox" Content="{loc:Loc IE_Forbid_falling_down}" IsThreeState="True"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/>
            <Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</local:EditorBase>
