<Window x:Class="HaCreator.GUI.InstanceEditor.LoadMapSelector" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:controls="clr-namespace:HaCreator.CustomControls" Title="{loc:Loc IE_Select_a_map}" Width="820" Height="600" MinWidth="560" MinHeight="420" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Background="{StaticResource HareCanvasBrush}" Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBox x:Name="searchBox" ToolTip="{loc:Loc IE_Search_maps}" TextChanged="SearchBox_TextChanged"/><controls:MapBrowserWpf x:Name="mapBrowser" Grid.Row="1" Margin="0,8"/><Button x:Name="selectButton" Grid.Row="2" HorizontalAlignment="Right" MinWidth="120" Style="{StaticResource HarePrimaryButtonStyle}" Content="{loc:Loc IE_Select}" Click="SelectButton_Click"/></Grid>
</Window>
