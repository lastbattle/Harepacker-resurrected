<Window x:Class="HaCreator.GUI.InstanceEditor.LoadJobSelector" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" Title="{loc:Loc IE_Select_a_job}" Width="520" Height="620" MinWidth="380" MinHeight="400" WindowStartupLocation="CenterOwner" PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Background="{StaticResource HareCanvasBrush}" Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="72"/></Grid.RowDefinitions><TextBox x:Name="searchBox" ToolTip="{loc:Loc IE_Search_jobs}" TextChanged="SearchBox_TextChanged"/><ListBox x:Name="resultsList" Grid.Row="1" Margin="0,8" SelectionChanged="ResultsList_SelectionChanged"/><Border Grid.Row="2" Style="{StaticResource HareCardStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock x:Name="descriptionText" VerticalAlignment="Center" FontWeight="SemiBold"/><Button x:Name="selectButton" Grid.Column="1" Style="{StaticResource HarePrimaryButtonStyle}" Content="{loc:Loc IE_Select}" IsEnabled="False" Click="SelectButton_Click"/></Grid></Border></Grid>
</Window>
