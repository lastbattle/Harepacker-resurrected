<Window x:Class="HaCreator.GUI.InstanceEditor.LoadQuestSelector" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" Title="{loc:Loc IE_Select_a_quest}" Width="680" Height="680" MinWidth="460" MinHeight="440" WindowStartupLocation="CenterOwner" PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Background="{StaticResource HareCanvasBrush}" Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="125"/></Grid.RowDefinitions><TextBox x:Name="searchBox" ToolTip="{loc:Loc IE_Search_quests}" TextChanged="SearchBox_TextChanged"/><ListBox x:Name="resultsList" Grid.Row="1" Margin="0,8" SelectionChanged="ResultsList_SelectionChanged"/><Border Grid.Row="2" Style="{StaticResource HareCardStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock x:Name="nameText" FontWeight="SemiBold"/><TextBlock x:Name="descriptionText" Margin="0,5,10,0" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/></StackPanel><Button x:Name="selectButton" Grid.Column="1" Style="{StaticResource HarePrimaryButtonStyle}" Content="{loc:Loc IE_Select}" IsEnabled="False" Click="SelectButton_Click"/></Grid></Border></Grid>
</Window>
