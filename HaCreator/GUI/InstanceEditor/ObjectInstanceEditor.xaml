<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.ObjectInstanceEditor"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI"
 Title="{loc:Loc IE_Object_instance}" Width="660" Height="720" MinHeight="560">
 <local:EditorBase.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></local:EditorBase.Resources>
 <Grid Background="{StaticResource HareCanvasBrush}" Margin="16">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <TextBlock x:Name="pathLabel" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/>
  <ScrollViewer Grid.Row="1" Margin="0,12"><StackPanel>
   <UniformGrid Columns="3"><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_X}"/><TextBox x:Name="xInput"/></StackPanel><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_Y}"/><TextBox x:Name="yInput"/></StackPanel><StackPanel><TextBlock Text="{loc:Loc IE_Z}"/><TextBox x:Name="zInput"/></StackPanel></UniformGrid>
   <WrapPanel Margin="0,14,0,8"><CheckBox x:Name="rBox" Content="{loc:Loc IE_R}"/><CheckBox x:Name="flipBox" Margin="16,2,0,2" Content="{loc:Loc IE_Flip}"/><CheckBox x:Name="hideBox" Margin="16,2,0,2" Content="{loc:Loc IE_Hidden}"/><CheckBox x:Name="flowBox" Margin="16,2,0,2" Content="{loc:Loc IE_Flow}"/><CheckBox x:Name="reactorBox" Margin="16,2,0,2" Content="{loc:Loc IE_Reactor}"/><CheckBox x:Name="dynamicBox" Margin="16,2,0,2" Content="{loc:Loc IE_Dynamic}"/></WrapPanel>
   <CheckBox x:Name="nameEnable" Content="{loc:Loc IE_Name}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="nameBox" Margin="22,4,0,10"/>
   <UniformGrid Columns="2"><StackPanel Margin="0,0,8,0"><CheckBox x:Name="rxBox" Content="{loc:Loc IE_RX}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="rxInt" Margin="22,4,0,8"/><CheckBox x:Name="cxBox" Content="{loc:Loc IE_CX}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="cxInt" Margin="22,4,0,8"/></StackPanel><StackPanel><CheckBox x:Name="ryBox" Content="{loc:Loc IE_RY}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="ryInt" Margin="22,4,0,8"/><CheckBox x:Name="cyBox" Content="{loc:Loc IE_CY}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="cyInt" Margin="22,4,0,8"/></StackPanel></UniformGrid>
   <CheckBox x:Name="tagsEnable" Content="{loc:Loc IE_Tags}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="tagsBox" Margin="22,4,0,10"/>
   <CheckBox x:Name="questEnable" Content="{loc:Loc IE_Quest_states}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><Grid Margin="22,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ListBox x:Name="questList" Height="100"/><StackPanel Grid.Column="1" Margin="8,0,0,0"><Button x:Name="questAdd" Content="{loc:Loc IE_Add}" Click="QuestAdd_Click"/><Button x:Name="questRemove" Margin="0,6,0,0" Content="{loc:Loc IE_Remove}" Click="QuestRemove_Click"/></StackPanel></Grid>
  </StackPanel></ScrollViewer>
  <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/></StackPanel>
 </Grid>
</local:EditorBase>
