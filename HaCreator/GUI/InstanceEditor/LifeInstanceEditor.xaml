<local:EditorBase x:Class="HaCreator.GUI.InstanceEditor.LifeInstanceEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HaCreator.GUI.Localization" xmlns:local="clr-namespace:HaCreator.GUI" Title="{loc:Loc IE_Life_instance}" Width="560" Height="610" ResizeMode="NoResize"><local:EditorBase.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></local:EditorBase.Resources><Grid Background="{StaticResource HareCanvasBrush}" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="pathLabel" Foreground="{StaticResource HareMutedTextBrush}" TextWrapping="Wrap"/><ScrollViewer Grid.Row="1" Margin="0,12"><StackPanel><UniformGrid Columns="2"><StackPanel Margin="0,0,8,0"><TextBlock Text="{loc:Loc IE_X}"/><TextBox x:Name="xInput" Margin="0,4,0,10"/><TextBlock Text="{loc:Loc IE_RX0_shift}"/><TextBox x:Name="rx0Box" Margin="0,4,0,10"/><TextBlock Text="{loc:Loc IE_Y_shift}"/><TextBox x:Name="yShiftBox" Margin="0,4,0,10"/></StackPanel><StackPanel><TextBlock Text="{loc:Loc IE_Y}"/><TextBox x:Name="yInput" Margin="0,4,0,10"/><TextBlock Text="{loc:Loc IE_RX1_shift}"/><TextBox x:Name="rx1Box" Margin="0,4,0,10"/></StackPanel></UniformGrid><CheckBox x:Name="mobTimeEnable" Content="{loc:Loc IE_Mob_time}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="mobTimeBox" Margin="22,3,0,9"/><CheckBox x:Name="infoEnable" Content="{loc:Loc IE_Info}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="infoBox" Margin="22,3,0,9"/><CheckBox x:Name="teamEnable" Content="{loc:Loc IE_Team}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="teamBox" Margin="22,3,0,9"/><CheckBox x:Name="limitedNameEnable" Content="{loc:Loc IE_Limited_name}" Checked="Optional_Changed" Unchecked="Optional_Changed"/><TextBox x:Name="limitedNameBox" Margin="22,3,0,9"/><StackPanel Orientation="Horizontal"><CheckBox x:Name="hideBox" Content="{loc:Loc IE_Hidden}"/><CheckBox x:Name="flipBox" Margin="18,2,0,2" Content="{loc:Loc IE_Flip}"/></StackPanel></StackPanel></ScrollViewer><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="{loc:Loc IE_Cancel}" IsCancel="True" Click="Cancel_Click"/><Button Margin="8,0,0,0" Content="{loc:Loc IE_OK}" Style="{StaticResource HarePrimaryButtonStyle}" Click="Ok_Click"/></StackPanel></Grid></local:EditorBase>
