<Window x:Class="HaCreator.GUI.ExceptionHandler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogLoc="clr-namespace:HaCreator.GUI.Localization"
        Title="{dialogLoc:DialogText Dialog_HaCreator_encountered_an_error_9237B9}" Width="620" SizeToContent="Height"
        MinWidth="480" MaxHeight="620" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource HareCanvasBrush}" FontFamily="Segoe UI">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HaSharedLibrary;component/GUI/Themes/HarepackerTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource HareCardStyle}">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Width="32" Height="32" VerticalAlignment="Top" Background="#FEE2E2" CornerRadius="7">
                    <TextBlock Text="!" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="19" FontWeight="Bold" Foreground="{DynamicResource HareDangerBrush}"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="crashMessageText" Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource HareTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="88" IsCancel="True" Content="{dialogLoc:DialogText Dialog_Close_7D9EB7}"/>
            <Button x:Name="restartButton" MinWidth="150" Margin="8,0,0,0" IsDefault="True"
                    Style="{StaticResource HarePrimaryButtonStyle}" Click="Restart_Click"/>
        </StackPanel>
    </Grid>
</Window>
